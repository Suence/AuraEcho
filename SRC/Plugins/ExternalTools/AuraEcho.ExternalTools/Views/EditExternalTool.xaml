<UserControl x:Class="AuraEcho.ExternalTools.Views.EditExternalTool"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:AuraEcho.ExternalTools.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:EditExternalToolViewModel}"
             d:DesignHeight="600"
             d:DesignWidth="855"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#80000000"
             mc:Ignorable="d">
    <Grid>
        <Border Width="400"
                Height="300"
                CornerRadius="8"
                Background="{DynamicResource Themes.Brushes.Background}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0">
                    <TextBlock Margin="16, 8"
                               HorizontalAlignment="Left"
                               FontSize="16"
                               Text="Edit EXTERNAL TOOL" />
                    <Line Margin="0,0,0,12"
                          Stretch="Fill"
                          Stroke="#333333"
                          StrokeThickness="1"
                          UseLayoutRounding="True"
                          X1="0"
                          X2="1"
                          Y1="0"
                          Y2="0" />
                    <StackPanel Margin="16, 0">
                        <TextBlock Margin="0,0,0,4" Text="NAME" />
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0, 0, 0, 8"/>

                        <TextBlock Margin="0,0,0,4" Text="COMMAND" />
                        <TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}" Margin="0, 0, 0, 8"/>

                        <TextBlock Margin="0,0,0,4" Text="ARGUMENTS" />
                        <TextBox Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Margin="16"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Margin="4"
                            Padding="16,4"
                            Command="{Binding CancelCommand}"
                            Content="CANCEL" />
                    <Button Margin="4"
                            Padding="16,4"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding SubmitCommand}"
                            Content="CONFIRM"
                            IsDefault="True" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
