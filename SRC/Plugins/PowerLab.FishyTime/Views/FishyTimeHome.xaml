<UserControl x:Class="PowerLab.FishyTime.Views.FishyTimeHome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             av:DesignHeight="400"
             av:DesignWidth="600"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="av">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock HorizontalAlignment="Left"
                       FontSize="24"
                       Text="FISHY TIME HOME" 
                       Margin="0, 0, 0, 12"/>
            <Line Stretch="Fill"
                  Stroke="#333333"
                  StrokeThickness="1"
                  UseLayoutRounding="True"
                  X1="0"
                  X2="1"
                  Y1="0"
                  Y2="0"
                  Margin="0, 0, 0, 12"/>
            <TextBlock Text="WINDOWS UPDATE" FontSize="16" Margin="0, 0, 0, 8"/>
            <Border BorderThickness="1" BorderBrush="#333333"
                    Height="40"
                    Padding="8">
                <DockPanel LastChildFill="True">
                    <Button Content="START" DockPanel.Dock="Right" Padding="8, 0" Click="OpenWindowsUpdateWindowButton_Click"/>
                    <TextBlock Text="OPEN WINDOWS UPDATE WINDOW" VerticalAlignment="Center" Margin="0, 0, 8, 0"/>
                </DockPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
