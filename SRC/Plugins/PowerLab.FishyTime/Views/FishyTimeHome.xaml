<UserControl x:Class="PowerLab.FishyTime.Views.FishyTimeHome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PowerLab.FishyTime.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PowerLab.FishyTime.Models"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.FishyTime.ViewModels"
             av:Background="#EFEFEF"
             av:DataContext="{av:DesignInstance Type=viewmodels:FishyTimeHomeViewModel}"
             av:DesignHeight="735"
             av:DesignWidth="585"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Loaded="UserControl_Loaded"
             mc:Ignorable="av">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <ScrollViewer Margin="0,24,0,0">
        <Grid Margin="24,0,24,24">
            <StackPanel>
                <TextBlock Margin="0,0,0,12"
                           HorizontalAlignment="Left"
                           FontSize="24"
                           Text="FISHY TIME" />
                <Line Margin="0,0,0,12"
                      Stretch="Fill"
                      Stroke="#333333"
                      StrokeThickness="1"
                      UseLayoutRounding="True"
                      X1="0"
                      X2="1"
                      Y1="0"
                      Y2="0" />
                <TextBlock Margin="0,0,0,8"
                           FontSize="16"
                           Text="WINDOWS UPDATE" />
                <Border Height="40"
                        Margin="0,0,0,8"
                        Padding="8"
                        BorderBrush="#333333"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <Button Padding="16,0"
                                Click="OpenWindowsUpdateWindowButton_Click"
                                Content="START"
                                DockPanel.Dock="Right" />
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="OPEN WINDOWS UPDATE WINDOW" />
                    </DockPanel>
                </Border>

                <TextBlock Margin="0,0,0,8"
                           FontSize="16"
                           Text="BOSS, I'M WORKING." />
                <Border Margin="0,0,0,8"
                        BorderBrush="#333333"
                        BorderThickness="1">

                    <StackPanel>

                        <Border Margin="4"
                                Padding="4"
                                BorderBrush="#333333"
                                BorderThickness="1">
                            <DockPanel LastChildFill="True">
                                <Button Width="20"
                                        DockPanel.Dock="Right"
                                        PreviewMouseLeftButtonDown="PickButton_MouseLeftButtonDown"
                                        PreviewMouseLeftButtonUp="PickButton_MouseLeftButtonUp" />
                                <StackPanel Orientation="Horizontal">
                                    <Image Width="16"
                                           Height="16"
                                           Margin="0,0,4,0"
                                           Source="{Binding ManagedWindowInfo.Icon, Converter={converters:IconToImageSourceConverter}}">
                                        <i:Interaction.Triggers>
                                            <i:DataTrigger Binding="{Binding ManagedWindowInfo}" Value="{x:Null}">
                                                <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                            </i:DataTrigger>
                                            <i:DataTrigger Binding="{Binding ManagedWindowInfo}"
                                                           Comparison="NotEqual"
                                                           Value="{x:Null}">
                                                <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                            </i:DataTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Text>
                                            <MultiBinding FallbackValue="DRAG THE ICON TO THE WINDOW YOU WANT TO ADJUST" StringFormat="{}{0}({1:X8})[{2}]">
                                                <Binding Path="ManagedWindowInfo.Name" />
                                                <Binding Path="ManagedWindowInfo.Handle" />
                                                <Binding Path="ManagedWindowInfo.WindowState" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <StackPanel>
                            <i:Interaction.Triggers>
                                <i:DataTrigger Binding="{Binding ManagedWindowInfo}" Value="{x:Null}">
                                    <i:ChangePropertyAction PropertyName="IsEnabled" Value="False" />
                                </i:DataTrigger>
                                <i:DataTrigger Binding="{Binding ManagedWindowInfo}"
                                               Comparison="NotEqual"
                                               Value="{x:Null}">
                                    <i:ChangePropertyAction PropertyName="IsEnabled" Value="True" />
                                </i:DataTrigger>
                            </i:Interaction.Triggers>
                            <StackPanel>
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding ManagedWindowInfo.WindowState}" Value="{x:Static models:ShowWindowCommands.Maximized}">
                                        <i:ChangePropertyAction PropertyName="IsEnabled" Value="False" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding ManagedWindowInfo.WindowState}"
                                                   Comparison="NotEqual"
                                                   Value="{x:Static models:ShowWindowCommands.Maximized}">
                                        <i:ChangePropertyAction PropertyName="IsEnabled" Value="True" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                                <DockPanel Margin="4" LastChildFill="True">
                                    <TextBlock Width="60"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left"
                                               Text="WIDTH" />
                                    <TextBox Width="60"
                                             VerticalAlignment="Center"
                                             DockPanel.Dock="Right"
                                             Text="{Binding ElementName=WidthSlider, Path=Value}" />
                                    <Slider x:Name="WidthSlider"
                                            Margin="0,0,4,0"
                                            Delay="10"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="10"
                                            Maximum="{Binding TargetScreenWidth}"
                                            Minimum="100"
                                            SmallChange="1"
                                            TickFrequency="1"
                                            Value="{Binding ManagedWindowInfo.Width}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="ValueChanged">
                                                <i:InvokeCommandAction Command="{Binding ApplyCommand}" CommandParameter="Rect" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                                <DockPanel Margin="4" LastChildFill="True">
                                    <TextBlock Width="60"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left"
                                               Text="HEIGHT" />
                                    <TextBox Width="60"
                                             VerticalAlignment="Center"
                                             DockPanel.Dock="Right"
                                             Text="{Binding ElementName=HeightSlider, Path=Value}" />
                                    <Slider x:Name="HeightSlider"
                                            Margin="0,0,4,0"
                                            IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="10"
                                            Maximum="{Binding TargetScreenHeight}"
                                            Minimum="100"
                                            SmallChange="1"
                                            TickFrequency="1"
                                            Value="{Binding ManagedWindowInfo.Height}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="ValueChanged">
                                                <i:InvokeCommandAction Command="{Binding ApplyCommand}" CommandParameter="Rect" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                            </StackPanel>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DockPanel Grid.Column="0" LastChildFill="True">
                                    <TextBlock Width="60"
                                               VerticalAlignment="Center"
                                               DockPanel.Dock="Left"
                                               Text="OPACITY" />
                                    <TextBlock Width="40"
                                               VerticalAlignment="Center"
                                               av:Text="100%"
                                               DockPanel.Dock="Right"
                                               Text="{Binding ManagedWindowInfo.Opacity, StringFormat={}{0:P0}}" />
                                    <Slider IsMoveToPointEnabled="True"
                                            IsSnapToTickEnabled="True"
                                            LargeChange="0.1"
                                            Maximum="1"
                                            Minimum="0"
                                            SmallChange="0.01"
                                            TickFrequency="0.01"
                                            Value="{Binding ManagedWindowInfo.Opacity}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="ValueChanged">
                                                <i:InvokeCommandAction Command="{Binding ApplyCommand}" CommandParameter="Opacity" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Slider>
                                </DockPanel>
                                <CheckBox Grid.Column="1"
                                          Margin="4"
                                          VerticalAlignment="Center"
                                          VerticalContentAlignment="Center"
                                          Command="{Binding ApplyCommand}"
                                          CommandParameter="Topmost"
                                          Content="TOPMOST"
                                          IsChecked="{Binding ManagedWindowInfo.IsTopmost}" />
                            </Grid>
                            <Line Margin="4"
                                  Stretch="Fill"
                                  Stroke="#333333"
                                  StrokeThickness="1"
                                  UseLayoutRounding="True"
                                  X1="0"
                                  X2="1"
                                  Y1="0"
                                  Y2="0" />
                            <CheckBox Margin="4"
                                      Content="ENABLE WINDOW MASK"
                                      FontSize="14" 
                                      IsChecked="{Binding FishyTimeConfig.IsWindowMaskEnabled}"
                                      Command="{Binding SaveDataCommand}"/>
                            <StackPanel x:Name="ModeLayout">
                                <Border Height="32"
                                        Margin="4"
                                        BorderBrush="#333333"
                                        BorderThickness="1">
                                    <DockPanel LastChildFill="True">
                                        <ComboBox x:Name="WindowMaskModeComboBox" Width="150"
                                                  Margin="4"
                                                  SelectedItem="{Binding FishyTimeConfig.WindowMaskMode}"
                                                  ItemsSource="{Binding WindowMaskModes}"
                                                  DockPanel.Dock="Right"
                                                  SelectedIndex="0">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="SelectionChanged">
                                                    <i:InvokeCommandAction Command="{Binding SwtichWindowMaskModeCommand}" CommandParameter="{Binding ElementName=WindowMaskModeComboBox, Path=SelectedItem}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </ComboBox>
                                        <TextBlock Margin="4"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Text="MODE" />
                                    </DockPanel>
                                </Border>


                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
