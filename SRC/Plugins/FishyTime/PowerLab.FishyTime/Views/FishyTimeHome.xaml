<UserControl x:Class="PowerLab.FishyTime.Views.FishyTimeHome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:PowerLab.FishyTime.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PowerLab.FishyTime.Models"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:utils="clr-namespace:PowerLab.FishyTime.Utils"
             xmlns:viewmodels="clr-namespace:PowerLab.FishyTime.ViewModels"
             av:DataContext="{av:DesignInstance Type=viewmodels:FishyTimeHomeViewModel}"
             av:DesignHeight="610"
             av:DesignWidth="495"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Loaded="UserControl_Loaded"
             mc:Ignorable="av">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <utils:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <DataTemplate x:Key="Win32WindowTemplate" DataType="{x:Type models:Win32Window}">
            <Border BorderBrush="#333333" BorderThickness="1">
                <StackPanel>
                    <Border Margin="4"
                            Padding="4"
                            BorderBrush="#333333"
                            BorderThickness="1">
                        <DockPanel LastChildFill="True">
                            <Button Padding="8,2"
                                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.RemoveWin32WindowCommand}"
                                    CommandParameter="{Binding}"
                                    DockPanel.Dock="Right">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="16" Height="16">
                                        <Path Data="m3.14644661 3.14644661c.19526215-.19526215.51184463-.19526215.70710678 0l4.14644661 4.14655339 4.1464466-4.14655339c.1735664-.17356635.4429908-.1928515.6378589-.05785545l.0692479.05785545c.1952621.19526215.1952621.51184463 0 .70710678l-4.1465534 4.14644661 4.1465534 4.1464466c.1735663.1735664.1928515.4429908.0578554.6378589l-.0578554.0692479c-.1952622.1952621-.5118446.1952621-.7071068 0l-4.1464466-4.1465534-4.14644661 4.1465534c-.17356635.1735663-.44299075.1928515-.63785889.0578554l-.06924789-.0578554c-.19526215-.1952622-.19526215-.5118446 0-.7071068l4.14655339-4.1464466-4.14655339-4.14644661c-.17356635-.17356635-.1928515-.44299075-.05785545-.63785889z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <StackPanel Margin="0,0,8,0" Orientation="Horizontal">
                                <Image Width="16"
                                       Height="16"
                                       Margin="0,0,4,0"
                                       Source="{Binding Icon, Converter={converters:IconToImageSourceConverter}}" />
                                <TextBlock VerticalAlignment="Center" av:Text="MainWndow(000000)[Normal]">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}({1:X8})[{2}]">
                                            <Binding Path="Name" />
                                            <Binding Path="Handle" />
                                            <Binding Path="WindowState" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                        </DockPanel>
                    </Border>

                    <StackPanel>
                        <StackPanel>
                            <i:Interaction.Triggers>
                                <i:DataTrigger Binding="{Binding WindowState}" Value="{x:Static models:ShowWindowCommands.Maximized}">
                                    <i:ChangePropertyAction PropertyName="IsEnabled" Value="False" />
                                </i:DataTrigger>
                                <i:DataTrigger Binding="{Binding WindowState}"
                                               Comparison="NotEqual"
                                               Value="{x:Static models:ShowWindowCommands.Maximized}">
                                    <i:ChangePropertyAction PropertyName="IsEnabled" Value="True" />
                                </i:DataTrigger>
                            </i:Interaction.Triggers>
                            <DockPanel Margin="4" LastChildFill="True">
                                <TextBlock Width="60"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left"
                                           Text="WIDTH" />
                                <TextBox Width="60"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Right"
                                         Text="{Binding ElementName=WidthSlider, Path=Value}" />
                                <Slider x:Name="WidthSlider"
                                        Margin="0,0,4,0"
                                        Delay="10"
                                        IsMoveToPointEnabled="True"
                                        IsSnapToTickEnabled="True"
                                        LargeChange="10"
                                        Maximum="{Binding MaxWidth}"
                                        Minimum="100"
                                        SmallChange="1"
                                        TickFrequency="1"
                                        Value="{Binding Width}" />
                            </DockPanel>
                            <DockPanel Margin="4" LastChildFill="True">
                                <TextBlock Width="60"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left"
                                           Text="HEIGHT" />
                                <TextBox Width="60"
                                         VerticalAlignment="Center"
                                         DockPanel.Dock="Right"
                                         Text="{Binding ElementName=HeightSlider, Path=Value}" />
                                <Slider x:Name="HeightSlider"
                                        Margin="0,0,4,0"
                                        IsMoveToPointEnabled="True"
                                        IsSnapToTickEnabled="True"
                                        LargeChange="10"
                                        Maximum="{Binding MaxHeight}"
                                        Minimum="100"
                                        SmallChange="1"
                                        TickFrequency="1"
                                        Value="{Binding Height}" />
                            </DockPanel>
                        </StackPanel>
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <DockPanel Grid.Column="0" LastChildFill="True" IsEnabled="{Binding CanSetOpacity}">
                                <TextBlock Width="60"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left"
                                           Text="OPACITY" />
                                <TextBlock Width="40"
                                           VerticalAlignment="Center"
                                           av:Text="100%"
                                           DockPanel.Dock="Right"
                                           Text="{Binding Opacity, StringFormat={}{0:P0}}" />
                                <Slider IsMoveToPointEnabled="True"
                                        IsSnapToTickEnabled="True"
                                        LargeChange="0.1"
                                        Maximum="1"
                                        Minimum="0"
                                        SmallChange="0.01"
                                        TickFrequency="0.01"
                                        Value="{Binding Opacity}" />
                            </DockPanel>
                            <CheckBox Grid.Column="1"
                                      Margin="4"
                                      VerticalAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      Content="TOPMOST"
                                      IsChecked="{Binding IsTopmost}" />
                        </Grid>
                        <Line Margin="4"
                              Stretch="Fill"
                              Stroke="#333333"
                              StrokeThickness="1"
                              UseLayoutRounding="True"
                              X1="0"
                              X2="1"
                              Y1="0"
                              Y2="0" />
                        <CheckBox Margin="4"
                                  HorizontalAlignment="Left"
                                  Content="ENABLE WINDOW MASK"
                                  FontSize="14"
                                  IsChecked="{Binding IsEnabledMask}" />
                        <StackPanel x:Name="ModeLayout" IsEnabled="{Binding IsEnabledMask}">
                            <Border Height="32"
                                    Margin="4"
                                    BorderBrush="#333333"
                                    BorderThickness="1">
                                <DockPanel LastChildFill="True">
                                    <ComboBox x:Name="WindowMaskModeComboBox"
                                              Width="150"
                                              Margin="4"
                                              DockPanel.Dock="Right"
                                              SelectedIndex="0"
                                              SelectedItem="{Binding MaskMode}">
                                        <ComboBox.ItemsSource>
                                            <x:Array Type="{x:Type models:WindowMaskMode}">
                                                <x:Static Member="models:WindowMaskMode.MouseLeave" />
                                                <x:Static Member="models:WindowMaskMode.HotZone" />
                                                <x:Static Member="models:WindowMaskMode.Spotlight" />
                                            </x:Array>
                                        </ComboBox.ItemsSource>
                                    </ComboBox>

                                    <TextBlock Margin="4"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Text="MODE" />
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer Margin="0,24,0,0" VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,0,24,24">
            <StackPanel>
                <TextBlock Margin="0,0,0,12"
                           HorizontalAlignment="Left"
                           FontSize="24"
                           Foreground="{DynamicResource FishyTime.Brand}"
                           Text="{Binding Source={x:Static utils:FishyTimeResources.Current}, Path=Strings.PluginName}" />
                <Line Margin="0,0,0,12"
                      Stretch="Fill"
                      Stroke="#333333"
                      StrokeThickness="1"
                      UseLayoutRounding="True"
                      X1="0"
                      X2="1"
                      Y1="0"
                      Y2="0" />
                <TextBlock Margin="0,0,0,8"
                           FontSize="16"
                           Text="WINDOWS UPDATE" />
                <Border Height="40"
                        Margin="0,0,0,8"
                        Padding="8"
                        BorderBrush="#333333"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <Button Padding="16,0"
                                Click="OpenWindowsUpdateWindowButton_Click"
                                Content="START"
                                DockPanel.Dock="Right" />
                        <TextBlock Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="OPEN WINDOWS UPDATE WINDOW" />
                    </DockPanel>
                </Border>

                <TextBlock Margin="0,0,0,8"
                           FontSize="16"
                           Text="BOSS, I'M WORKING." />
                <Border Margin="0,0,0,8"
                        Padding="8,4"
                        BorderBrush="#333333"
                        BorderThickness="1">
                    <DockPanel LastChildFill="True">
                        <Button Width="24"
                                Height="24"
                                DockPanel.Dock="Right"
                                PreviewMouseLeftButtonDown="PickButton_MouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="PickButton_MouseLeftButtonUp">
                            <Viewbox Width="16"
                                     Height="16"
                                     VerticalAlignment="Center"
                                     RenderOptions.EdgeMode="Aliased"
                                     Stretch="Uniform">
                                <Canvas Width="16" Height="16">
                                    <Path Data="M 14.5 8 L 1.49 8.02"
                                          Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}"
                                          StrokeDashCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeThickness="1" />

                                    <Path Data="M 8 14.53 L 8 1.52"
                                          Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}"
                                          StrokeDashCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeThickness="1" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <TextBlock VerticalAlignment="Center" Text="DRAG THE ICON TO THE WINDOW YOU WANT TO ADJUST" />
                    </DockPanel>
                </Border>
                <ItemsControl av:ItemsSource="{av:SampleData ItemCount=2}"
                              ItemTemplate="{StaticResource Win32WindowTemplate}"
                              ItemsSource="{Binding Win32Windows}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,0,8" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
