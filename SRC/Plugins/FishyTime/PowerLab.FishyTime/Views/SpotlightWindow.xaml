<Window x:Class="PowerLab.FishyTime.Views.SpotlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:PowerLab.FishyTime.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:viewmodels="clr-namespace:PowerLab.FishyTime.ViewModels"
        Title="SpotlightWindow"
        Width="450"
        Height="451"
        d:DataContext="{d:DesignInstance Type=viewmodels:SpotlightWindowViewModel}"
        prism:ViewModelLocator.AutoWireViewModel="True"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        ResizeMode="NoResize"
        ShowActivated="False"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.Resources>
        <Storyboard x:Key="SpotlightLoadedAnimation">
            <DoubleAnimation Storyboard.TargetName="SpotlightBrush"
                             Storyboard.TargetProperty="(RadialGradientBrush.GradientStops)[0].(GradientStop.Offset)"
                             From="0"
                             To="0.3"
                             Duration="0:0:0" />
            <DoubleAnimation Storyboard.TargetName="SpotlightBrush"
                             Storyboard.TargetProperty="(RadialGradientBrush.GradientStops)[1].(GradientStop.Offset)"
                             From="1"
                             To="0.5"
                             Duration="0:0:0.5" />
        </Storyboard>
    </Window.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:ControlStoryboardAction Storyboard="{StaticResource SpotlightLoadedAnimation}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid x:Name="RootGrid" Background="#212121">
        <Grid.OpacityMask>
            <RadialGradientBrush x:Name="SpotlightBrush" Center="0.5, 0.5" GradientOrigin="0.5, 0.5" RadiusX=".5" RadiusY=".5">
                <GradientStop Offset=".3" Color="Transparent" />
                <GradientStop Offset=".5" Color="#FF000000" />
            </RadialGradientBrush>
        </Grid.OpacityMask>
    </Grid>

</Window>
