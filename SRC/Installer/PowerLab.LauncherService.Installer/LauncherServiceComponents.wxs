<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <ComponentGroup Id="LauncherServiceFileComponents" Directory="LauncherServiceFolder">
		<Files Include="$(var.PowerLab.LauncherService.TargetDir)**">
			<Exclude Files="*.pdb"/>
			<Exclude Files="PowerLabLauncherService.exe"/>
		</Files>
		<Component Id="ProductComponent" Guid="1577B0BC-EFED-4FC6-AD98-68DE350FACBC">
			<File Source="PowerLabLauncherService.exe" />

			<ServiceInstall Id="InstallLauncherService"
							Name="PowerLabLauncherService"
							DisplayName="PowerLab Launcher Service"
							Description="此服务用于启动和管理 PowerLab 的核心组件。如果此服务被禁用，PowerLab 可能无法正常启动或运行。"
							Start="auto"
							Type="ownProcess"
							ErrorControl="normal"
							Vital="yes"
							Account="LocalSystem" />

			<ServiceControl Id="ControlLauncherService"
							Name="PowerLabLauncherService"
							Start="install"
							Stop="both"
							Remove="uninstall"
							Wait="yes" />
		</Component>
    </ComponentGroup>
  </Fragment>
</Wix>
