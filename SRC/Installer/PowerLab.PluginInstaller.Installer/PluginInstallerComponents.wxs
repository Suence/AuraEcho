<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
	<Fragment>
		<ComponentGroup Id="FileComponents" Directory="INSTALLFOLDER">
			<Component Id="ProductComponent" Guid="F2F37407-114F-4E5E-8B26-5872152FD721">
				<File Id="PluginInstaller.exe" Source="$(var.PluginInstaller.TargetDir)PluginInstaller.exe" />
				<File Id="PluginInstaller.dll" Source="$(var.PluginInstaller.TargetDir)PluginInstaller.dll" />
				<File Id="PluginInstaller.runtimeconfig.json" Source="$(var.PluginInstaller.TargetDir)PluginInstaller.runtimeconfig.json" />
				<File Id="PluginInstaller.deps.json" Source="$(var.PluginInstaller.TargetDir)PluginInstaller.deps.json" />
			</Component>
		</ComponentGroup>

		<Component Id="FileAssociations" Guid="F850DAE9-1CA8-4529-BDA4-461C4FFFEA9E">
			<File Id="PowerLabIcon" Source="Assets/Icons/PowerLab.ico" />
			<ProgId Id="Suence.Plix" Description="PowerLab plugin file" Icon="PowerLabIcon">
				<Extension Id="plix" ContentType="application/plix" >
					<Verb Id="open" Command="Open" TargetFile="PluginInstaller.exe" Argument="&quot;%1&quot;" />
				</Extension>
			</ProgId>
		</Component>
	</Fragment>
</Wix>
