<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util" >
	<Package Name="PowerLab"
			 Manufacturer="Suencesoft"
			 Codepage="65001"
			 Scope="perMachine"
			 UpgradeCode="F2F37407-114F-4E5E-8B26-5872152FD721"
			 Version="$(var.Version)">
		<MajorUpgrade DowngradeErrorMessage="不允许降级安装" />
		<Launch Condition="MsiNTProductType = 1" Message="TODO Wrong OS type! TODO" />
		<MediaTemplate EmbedCab="yes"/>
		
		<Feature Id="Main">
			<ComponentGroupRef Id="AppFileComponents" />
			<ComponentRef Id="StartMenuShortcutComponent"/>
		</Feature>
		<Feature Id="DesktopShortcut">
			<ComponentRef Id="DesktopShortcutComponent"/>
		</Feature>

		<Feature Id="RunAtBoot">
			<ComponentRef Id="RunAtBootComponent" />
		</Feature>
	</Package>
</Wix>
