<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
	 xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
	 xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">
	
	<Bundle Name="PowerLab"
			Manufacturer="Suencesoft"
			Version="$(var.BundleVersion)"
			SplashScreenSourceFile="Assets/Images/splash_screen.bmp"
			IconSourceFile="Assets/Icons/PowerLab.ico"
			InProgressName="PLSU"
			UpgradeCode="73725F25-4E6A-4817-B1EC-69A577E59D25">
		
		<BootstrapperApplication Secondary="true" SourceFile="PowerLab.Setup.UI.exe">
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)mbanative.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.Setup.UI.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)DryIoc.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Microsoft.WindowsAPICodePack.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Microsoft.WindowsAPICodePack.Shell.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Microsoft.Xaml.Behaviors.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Prism.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Prism.DryIoc.Wpf.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)Prism.Wpf.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.Controls.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.Themes.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.PluginContracts.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.UIToolkit.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)WixToolset.BootstrapperApplicationApi.dll" />
			<Payload SourceFile="$(PowerLab.Setup.UI.TargetDir)PowerLab.Setup.UI.runtimeconfig.json" />

			<bal:WixPrerequisiteBootstrapperApplication Theme="standard" LogoFile="Assets/Icons/PowerLab.ico" LocalizationFile="Strings/zh-cn.wxl"/>
		</BootstrapperApplication>

		<netfx:DotNetCoreSearch
			RuntimeType="desktop"
			MajorVersion="10"
			Platform="x64"
			Variable="DOTNETDESKTOPVERSION" />

		<Variable Name="InstallFolder" Type="string" Value="[ProgramFiles6432Folder]PowerLab" />
		<ApprovedExeForElevation Id="LaunchMainApp" Key="Software\PowerLab" Value="LauncherPath" />
		
		<Chain DisableSystemRestore="yes">

			<!-- Permanent: 永久(卸载时保留) or 指定卸载参数 UninstallArguments="/uninstall /quiet /norestart" -->
			<ExePackage Id="DotNetDesktop"
						DetectCondition="DOTNETDESKTOPVERSION &gt;= &quot;10.0.0&quot;"
						Permanent="yes"
						Vital="no"
						RepairCondition="DOTNETDESKTOPVERSION &lt; &quot;10.0.0&quot;"
						bal:PrereqLicenseUrl="https://dotnet.microsoft.com"
						bal:PrereqPackage="yes"
						InstallArguments="windowsdesktop-runtime-10.0.0-win-x64.exe /install /quiet /norestart"
						RepairArguments="windowsdesktop-runtime-10.0.0-win-x64.exe /repair /quiet /norestart"
						UninstallArguments="windowsdesktop-runtime-10.0.0-win-x64.exe /uninstall /quiet /norestart">
				<ExePackagePayload Name="windowsdesktop-runtime-10.0.0-win-x64.exe" SourceFile="ExePackageFiles/windowsdesktop-runtime-10.0.0-win-x64.exe" />
			</ExePackage>
			
			<!-- PowerLab -->
			<MsiPackage Id="PowerLabInstallerMSI"
						Visible="yes"
						Compressed="yes"
						SourceFile="$(PowerLab.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
			</MsiPackage>
			
			<!-- PowerLab Launcher -->
			<MsiPackage Id="PowerLabLauncherMSI"
						Visible="yes"
						Compressed="yes"
						EnableFeatureSelection="yes"
						SourceFile="$(PowerLab.Launcher.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
				<MsiProperty Name="UNINSTALLER_PATH" Value="[UninstallerPath]"/>
			</MsiPackage>
			
			<!-- Plugin Installer -->
			<MsiPackage Id="PluginInstallerMSI"
						Visible="yes"
						Compressed="yes"
						SourceFile="$(PowerLab.PluginInstaller.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
			</MsiPackage>

			<!-- Data Migrator -->
			<MsiPackage Id="PowerLabDataMigratorMsi"
						Visible="yes"
						Compressed="yes"
						SourceFile="$(PowerLab.DataMigrator.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
			</MsiPackage>

			<!-- Updater Service -->
			<MsiPackage Id="PowerLabUpdaterServiceMsi"
						Visible="yes"
						Compressed="yes"
						SourceFile="$(PowerLab.UpdaterService.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
			</MsiPackage>

			<!-- Launcher Service -->
			<MsiPackage Id="PowerLabLauncherServiceMsi"
						Visible="yes"
						Compressed="yes"
						SourceFile="$(PowerLab.LauncherService.Installer.TargetFileName)">
				<MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]"/>
			</MsiPackage>
		</Chain>
	</Bundle>
</Wix>
