<Window x:Class="AuraEcho.Installer.Bootstrapper.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:constants="clr-namespace:AuraEcho.Installer.Bootstrapper.Constants"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:ui="http://ui.auraecho.com/"
        xmlns:viewmodels="clr-namespace:AuraEcho.Installer.Bootstrapper.ViewModels"
        Title="AuraEcho 安装向导"
        Width="750"
        Height="500"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        d:DesignHeight="500"
        d:DesignWidth="750"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Background="Black"
        Foreground="White"
        Loaded="Window_Loaded"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Command="{x:Static ApplicationCommands.Paste}" Gesture="Alt+Space" />
        <KeyBinding Command="{x:Static ApplicationCommands.Paste}" Gesture="Alt+F4" />
    </Window.InputBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="1"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CloseSplashScreenCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    
    <Grid>
        <ContentControl prism:RegionManager.RegionName="{x:Static constants:InstallerRegionNames.MainRegion}" />
        <ContentControl prism:RegionManager.RegionName="{x:Static constants:InstallerRegionNames.MessageRegion}" />
        <Grid Height="36"
              VerticalAlignment="Top"
              Background="Transparent"
              MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="40"
                        ui:ControlHelper.CornerRadius="0"
                        Click="Button_Click"
                        IsTabStop="False"
                        Style="{DynamicResource IconButtonStyle}">
                    <Button.Content>
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="24" Height="24">
                                <Path Data="M19,13H5V11H19V13Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                            </Canvas>
                        </Viewbox>
                    </Button.Content>
                </Button>
                <Button Width="40"
                        IsTabStop="False"
                        ui:ControlHelper.CornerRadius="0"
                        Command="{Binding ExitCommand}"
                        Style="{DynamicResource IconButtonStyle}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="16" Height="16">
                            <Path Data="m3.14644661 3.14644661c.19526215-.19526215.51184463-.19526215.70710678 0l4.14644661 4.14655339 4.1464466-4.14655339c.1735664-.17356635.4429908-.1928515.6378589-.05785545l.0692479.05785545c.1952621.19526215.1952621.51184463 0 .70710678l-4.1465534 4.14644661 4.1465534 4.1464466c.1735663.1735664.1928515.4429908.0578554.6378589l-.0578554.0692479c-.1952622.1952621-.5118446.1952621-.7071068 0l-4.1464466-4.1465534-4.14644661 4.1465534c-.17356635.1735663-.44299075.1928515-.63785889.0578554l-.06924789-.0578554c-.19526215-.1952622-.19526215-.5118446 0-.7071068l4.14655339-4.1464466-4.14655339-4.14644661c-.17356635-.17356635-.1928515-.44299075-.05785545-.63785889z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
            <TextBlock Margin="16,8"
                       HorizontalAlignment="Left"
                       FontSize="14"
                       Text="AuraEcho 安装向导" />
        </Grid>
    </Grid>
</Window>
