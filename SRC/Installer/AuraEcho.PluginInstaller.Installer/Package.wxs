<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="AuraEchoPluginInstaller"
		   Manufacturer="Suencesoft" 
		   Version="$(var.Version)"
		   Codepage="65001"
		   Scope="perMachine"
		   UpgradeCode="50E1E8C4-5997-466B-8A2D-0307A086C810">
	  
	  <MajorUpgrade DowngradeErrorMessage="不允许降级安装" />
	  
	  <!--UpgradeCode="8D5E5DFF-2706-48F8-B247-1004FEE56DAD"-->
	  <!-- 需要 AuraEcho 前置安装条件 -->
	  
	  <MediaTemplate EmbedCab="yes"/>

	  <Feature Id="Main">
		  <ComponentGroupRef Id="FileComponents" />
		  <ComponentRef Id="FileAssociations"/>
	  </Feature>
  </Package>
</Wix>
