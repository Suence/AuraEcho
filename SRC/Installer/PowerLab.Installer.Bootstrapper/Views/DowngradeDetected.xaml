<UserControl x:Class="PowerLab.Installer.Bootstrapper.Views.DowngradeDetected"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.Installer.Bootstrapper.ViewModels"
             av:DataContext="{av:DesignInstance Type=viewmodels:DowngradeDetectedViewModel}"
             av:DesignHeight="676"
             av:DesignWidth="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#1B1B1B"
             mc:Ignorable="av">
    <Grid>
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="48"
                   Foreground="#EFEFEF"
                   Text="已安装更高版本" />
    </Grid>
</UserControl>
