<UserControl x:Class="PowerLab.Installer.Bootstrapper.Views.Uninstalling"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.Installer.Bootstrapper.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:UninstallingViewModel}"
             d:DesignHeight="625"
             d:DesignWidth="1030"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Storyboard x:Key="ProgressStorybard">
            <DoubleAnimation Storyboard.TargetName="UninstallProgressBar"
                             Storyboard.TargetProperty="Value"
                             Duration="0:0:2" />
        </Storyboard>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding UninstallCommand}" />
        </i:EventTrigger>
        <i:PropertyChangedTrigger Binding="{Binding Progress}">
            <i:CallMethodAction MethodName="BeginProgressStoryboard" TargetObject="{Binding RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </i:PropertyChangedTrigger>
    </i:Interaction.Triggers>
    <Grid Background="#202020">
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="25"
                   Foreground="#DFDFDF"
                   Text="正在卸载..." />
        <StackPanel Grid.Row="1"
                    Margin="24"
                    VerticalAlignment="Bottom">
            <DockPanel Margin="0,0,0,16" LastChildFill="False">
                <TextBlock d:Text="正在安装，请稍后..."
                           DockPanel.Dock="Left"
                           FontSize="14"
                           Foreground="#EFEFEF"
                           Text="{Binding Message}" />
                <TextBlock d:Text="10%"
                           DockPanel.Dock="Right"
                           Foreground="#EFEFEF"
                           Text="{Binding ElementName=UninstallProgressBar, Path=Value, StringFormat={}{0:N0}%}" />
            </DockPanel>
            <ProgressBar x:Name="UninstallProgressBar"
                         Height="16 "
                         Margin="0,0,0,24"
                         d:Value="10"
                         Maximum="100"
                         Minimum="0" />
            <Button Width="75"
                    Height="36"
                    HorizontalAlignment="Right"
                    BorderThickness="1"
                    Content="取消"
                    FontSize="14" />
        </StackPanel>
    </Grid>
</UserControl>
