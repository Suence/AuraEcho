<UserControl x:Class="PowerLab.Installer.Bootstrapper.Views.InstallPreparation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.Installer.Bootstrapper.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:InstallPreparationViewModel}"
             d:DesignHeight="676"
             d:DesignWidth="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <Grid Background="#F9FAFC">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Margin="0,112,0,0"
                    HorizontalAlignment="Center">
            <Image Width="160"
                   Height="160"
                   Margin="0,0,0,19"
                   Source="/Assets/Images/powerlab.png" />
            <StackPanel Margin="0,0,0,63"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#1b1b1b"
                           Text="PowerLab" />
                <TextBlock VerticalAlignment="Center"
                           d:Text="V1.2.0"
                           FontSize="24"
                           Foreground="#4c4c4c"
                           Text="{Binding Version, StringFormat=V{0}}" />
            </StackPanel>
            <StackPanel x:Name="CustomInstallationLayout"
                        d:Visibility="Visible"
                        Visibility="Hidden">
                <StackPanel Height="40"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Margin="0,0,16,0"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="#1b1b1b"
                               Text="安装路径:"
                               TextOptions.TextFormattingMode="Display" />
                    <Border Width="548"
                            Padding="8,0"
                            BorderBrush="#d1d1d1"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TargetInstallFolderTextBlock"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       d:Text="C:\Program Files(x86)\Lenovo\PowerLab"
                                       FontSize="14"
                                       Text="{Binding TargetInstallFolder, Mode=TwoWay}" />
                            <Button Grid.Column="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Click="SelectFolderButton_Click"
                                    Foreground="#333333"
                                    Style="{DynamicResource IconButtonStyle}">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="16"
                                            Height="16"
                                            UseLayoutRounding="False">
                                        <Path Data="M 1.5 4.5 V 2.5 H 6.5 L 8.5 4.5 H 14.5 V 13.5 H 1.5 V 4.5 Z"
                                              Stroke="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Foreground}"
                                              StrokeDashCap="Flat"
                                              StrokeLineJoin="Round"
                                              StrokeThickness="1" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Margin="0,0,0,48"
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                    <CheckBox Margin="0,0,64,0"
                              Content="创建桌面图标"
                              IsChecked="{Binding IsCreateDesktopFolderShortcut}" />
                    <CheckBox Margin="0,0,64,0"
                              Content="添加到快速启动栏"
                              IsChecked="True" />
                    <CheckBox Content="开机默认启动 " IsChecked="{Binding IsRunAtBoot}" />
                </StackPanel>
            </StackPanel>
            <Button Width="216"
                    Height="72"
                    HorizontalAlignment="Center"
                    Command="{Binding InstallCommand}"
                    Content="快速安装"
                    FontSize="24"
                    Foreground="White"
                    Style="{DynamicResource PrimaryButtonStyle}"
                    TextOptions.TextFormattingMode="Display" />
        </StackPanel>
        <Grid Grid.Row="1" Margin="24">
            <DockPanel x:Name="RegularInstallation" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">

                    <CheckBox d:IsChecked="True"
                              Content="阅读并同意"
                              FontSize="14"
                              IsChecked="{Binding AgreeAgreement}" />
                    <TextBlock FontSize="14">
                        <Hyperlink Command="{Binding OpenCloudServiceAgreementCommand}">
                            用户协议
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <TextBlock Margin="0,0,6,0" FontSize="14">
                        <Hyperlink x:Name="CustomInstallationHyperLink" Click="CustomInstallationHyperLink_Click">
                            <Run x:Name="CustomInstallationRun">自定义安装</Run>
                        </Hyperlink>
                    </TextBlock>
                    <Canvas Width="6"
                            Height="10"
                            RenderTransformOrigin=".5, .5"
                            UseLayoutRounding="False">
                        <Canvas.RenderTransform>
                            <ScaleTransform ScaleX="-1" />
                        </Canvas.RenderTransform>
                        <Path Data="M 4.71484 8.85693 L 0.85714 5.03052 L 4.71484 1.22459" Fill="{Binding ElementName=CustomInstallationHyperLink, Path=Foreground}" />
                        <Path Data="M 4.71484 8.85693 L 0.85714 5.03052 L 4.71484 1.22459"
                              Stroke="#ffa3a3a3"
                              StrokeDashCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeStartLineCap="Round"
                              StrokeThickness="1" />
                    </Canvas>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
