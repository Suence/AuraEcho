<UserControl x:Class="PowerLab.Installer.Bootstrapper.Views.InstallFinish"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.Installer.Bootstrapper.ViewModels"
             av:DataContext="{av:DesignInstance Type=viewmodels:InstallFinishViewModel}"
             av:DesignHeight="676"
             av:DesignWidth="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#F9FAFC"
             mc:Ignorable="av">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Margin="0,106,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">
                <Image Width="208" Height="208" />
                <TextBlock HorizontalAlignment="Center"
                           FontSize="24"
                           Foreground="White"
                           Text="恭喜你，安装成功！" />
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1" Height="154">
            <Button Width="176"
                    Height="56"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Command="{Binding FinishedCommand}"
                    Content="立即体验"
                    Style="{DynamicResource PrimaryButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>
