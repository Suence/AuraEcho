<Window x:Class="PowerLab.Installer.Bootstrapper.Views.InstallerAlreadyRunningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PowerLab.Installer.Bootstrapper.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="InstallerAlreadyRunningDialog"
        Width="335"
        Height="165"
        Background="#1B1B1B"
        Foreground="#EFEFEF"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.InputBindings>
        <KeyBinding Command="{x:Static ApplicationCommands.Paste}" Gesture="Alt+Space" />
        <KeyBinding Command="{x:Static ApplicationCommands.Paste}" Gesture="Alt+F4" />
    </Window.InputBindings>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="1"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0"
              Height="36"
              VerticalAlignment="Top"
              Background="Transparent"
              MouseLeftButtonDown="Grid_MouseLeftButtonDown">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="40"
                        Click="CloseWindowButton_Click"
                        Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=Foreground}"
                        Style="{DynamicResource IconButtonStyle}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="16" Height="16">
                            <Path Data="m3.14644661 3.14644661c.19526215-.19526215.51184463-.19526215.70710678 0l4.14644661 4.14655339 4.1464466-4.14655339c.1735664-.17356635.4429908-.1928515.6378589-.05785545l.0692479.05785545c.1952621.19526215.1952621.51184463 0 .70710678l-4.1465534 4.14644661 4.1465534 4.1464466c.1735663.1735664.1928515.4429908.0578554.6378589l-.0578554.0692479c-.1952622.1952621-.5118446.1952621-.7071068 0l-4.1464466-4.1465534-4.14644661 4.1465534c-.17356635.1735663-.44299075.1928515-.63785889.0578554l-.06924789-.0578554c-.19526215-.1952622-.19526215-.5118446 0-.7071068l4.14655339-4.1464466-4.14655339-4.14644661c-.17356635-.17356635-.1928515-.44299075-.05785545-.63785889z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Button}}, Path=Foreground}" />
                        </Canvas>
                    </Viewbox>
                </Button>
            </StackPanel>
            <TextBlock Margin="16,8"
                       HorizontalAlignment="Left"
                       FontSize="14"
                       Text="提示" />
        </Grid>
        <TextBlock Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="另一个安装程序已在运行。" />
        <Button Grid.Row="2"
                Margin="16"
                Padding="16,4"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Click="CloseWindowButton_Click"
                Content="确定" />
    </Grid>
</Window>
