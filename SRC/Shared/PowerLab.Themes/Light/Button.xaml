<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:powerlab="http://ui.powerlab.com/">
    <!--  常规按钮模板  -->
    <ControlTemplate x:Key="RegularButtonTemplate" TargetType="{x:Type Button}">
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                ClipToBounds="{TemplateBinding ClipToBounds}"
                CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(powerlab:ControlHelper.CornerRadius)}"
                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                TextBlock.Foreground="{TemplateBinding Foreground}"
                UseLayoutRounding="{TemplateBinding UseLayoutRounding}">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Focusable="False"
                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
        </Border>
    </ControlTemplate>

    <!--  窗口标题图标按钮样式  -->
    <Style x:Key="AppTitleButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppTitleButton.Normal.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTitleButton.Normal.Foreground}" />
        <Setter Property="Template" Value="{StaticResource RegularButtonTemplate}" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AppTitleButton.Hover.Background}" />
                <Setter Property="Foreground" Value="{DynamicResource AppTitleButton.Hover.Foreground}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource IconButton.Disable.Foreground}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  关闭按钮样式  -->
    <Style x:Key="CloseButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="5" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppTitleButton.Normal.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTitleButton.Normal.Foreground}" />
        <Setter Property="Template" Value="{StaticResource RegularButtonTemplate}" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource CloseButton.Hover.Background}" />
                <Setter Property="Foreground" Value="{DynamicResource CloseButton.Hover.Foreground}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>