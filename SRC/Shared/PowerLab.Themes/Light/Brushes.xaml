<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="App.Background" Color="#EFEFEF" />
    <SolidColorBrush x:Key="App.Background2" Color="#FFF3F3F3" />
    
    <SolidColorBrush x:Key="App.Foreground" Color="#212121" />
    <SolidColorBrush x:Key="App.Foreground2" Color="#FF7F7F83" />

    <SolidColorBrush x:Key="AppTitleButton.Pressed.Background" Color="#60000000" />
    
    <DrawingBrush x:Key="Shader.Brush"
                  TileMode="Tile"
                  Viewport="0,0,20,20"
                  ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <DrawingGroup.Children>
                    <!--<GeometryDrawing Brush="#FF111111">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,1,1" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>-->
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L10,0 10,0.1, 0,0.1Z" />
                    <GeometryDrawing Brush="Gray" Geometry="M0,0 L0,10 0.1,10, 0.1,0Z" />
                </DrawingGroup.Children>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>
</ResourceDictionary>