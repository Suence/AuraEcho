<UserControl x:Class="PowerLab.UIToolkit.ContentDialog.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PowerLab.UIToolkit.ContentDialog"
             Background="#60000000"
             Foreground="#EFEFEF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=local:ConfirmDialogViewModel}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">
    <Grid Width="320"
          Height="150"
          Background="#212121">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Height="24" Grid.Row="0">
            <TextBlock Text="{Binding Parameter.Title}"
                       d:Text="Dialog Title"
                       Margin="4"
                       
                       VerticalAlignment="Center" />
            <Button Content="X" Command="{Binding CloseCommand}" HorizontalAlignment="Right" Padding="12, 0"/>
        </Grid>
        <TextBlock Margin="0,0,0,10"
                   Grid.Row="1"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Text="{Binding Parameter.Message}"
                   d:Text="Are you sure?" />
        <StackPanel HorizontalAlignment="Right"
                    Grid.Row="2"
                    Margin="8"
                    Orientation="Horizontal">
            <Button Margin="0, 0, 8, 0"  Padding="8, 4" Command="{Binding CancelCommand}"
                    Content="{Binding Parameter.CancelText}" />
            <Button Command="{Binding OkCommand}"
                    Padding="8, 4"
                    Content="{Binding Parameter.ConfirmText}" />
        </StackPanel>
    </Grid>
</UserControl>
