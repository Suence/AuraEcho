<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="clr-namespace:AuraEcho.Themes.AttachedProperties">

    <Style x:Key="NoAppearanceTextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Padding" Value="5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Themes.Brushes.OnSecondary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="LayoutRoot"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            ClipToBounds="{TemplateBinding ClipToBounds}"
                            CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                            TextBlock.Foreground="{TemplateBinding Foreground}"
                            UseLayoutRounding="{TemplateBinding UseLayoutRounding}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Focusable="False"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="LayoutRoot"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{DynamicResource Themes.Colors.SecondaryFixed}"
                                                        Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="LayoutRoot"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#05FFFFFF"
                                                        Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- PasswordBox 模板 -->
    <ControlTemplate x:Key="RegularPasswordBoxTemplate" TargetType="{x:Type PasswordBox}">
        <ControlTemplate.Resources />
        <Grid>
            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="PART_ContentHost"
                                  VerticalAlignment="Center"
                                  Focusable="False"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden" />
                    <TextBox x:Name="PlainTextBox"
                             Grid.Column="0"
                             Grid.ColumnSpan="2"
                             Padding="{TemplateBinding Padding}"
                             ui:ControlHelper.CornerRadius="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.CornerRadius)}"
                             BorderThickness="0" 
                             InputMethod.IsInputMethodEnabled="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(InputMethod.IsInputMethodEnabled)}"
                             MaxLength="{TemplateBinding MaxLength}"
                             Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:PasswordBoxHelper.Password), Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="Hidden"/>
                    <TextBlock x:Name="PlaceHolderTextBlock"
                               Margin="{TemplateBinding Padding}"
                               Padding="2,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                               Focusable="False"
                               FontSize="{TemplateBinding FontSize}"
                               Foreground="#999999"
                               IsHitTestVisible="False"
                               Text="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}, Path=(ui:ControlHelper.PlaceHolder)}"
                               Visibility="Hidden" />
                    <ToggleButton x:Name="SwitchButton"
                                  Grid.Column="1"
                                  Margin="0,0,2,2"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Focusable="False"
                                  IsTabStop="False"
                                  Style="{StaticResource ToggleButtonStyle}">
                        <Canvas x:Name="SwitchButtonIcon"
                                Width="16.0"
                                Height="16.0"
                                UseLayoutRounding="True">
                            <Path Data="M 14.98 7.83 C 14.99 7.84 15 7.91 15 8 C 15 8.09 14.99 8.16 14.98 8.21 L 14.98 8.21 L 14.98 8.21 C 14.98 8.21 14.98 8.27 14.95 8.34 C 14.95 8.35 14.95 8.36 14.94 8.37 C 14.93 8.4 14.92 8.43 14.9 8.47 C 13.63 11.47 10.85 13.5 8 13.5 C 5.16 13.5 2.38 11.47 1.08 8.44 C 1.08 8.42 1.07 8.4 1.06 8.38 C 1.05 8.35 1.04 8.31 1.03 8.28 H 1.03 C 1.03 8.24 1.02 8.2 1.02 8.17 C 1.01 8.15 1 8.05 1 8.05 C 1 8.02 1 7.99 1 7.95 C 1 7.95 1.01 7.84 1.03 7.78 C 1.02 7.79 1.02 7.74 1.05 7.66 C 1.05 7.65 1.05 7.65 1.05 7.65 C 1.05 7.64 1.06 7.64 1.06 7.63 C 1.07 7.6 1.08 7.57 1.09 7.54 C 2.38 4.53 5.16 2.5 8 2.5 C 10.85 2.5 13.62 4.53 14.92 7.56 C 14.92 7.58 14.93 7.6 14.94 7.63 C 14.94 7.63 14.94 7.63 14.94 7.64 C 14.95 7.64 14.95 7.65 14.95 7.66 C 14.96 7.7 14.98 7.78 14.98 7.83 Z M 14.05 8.05 C 14.06 8.04 14.06 8.04 14.06 8.04 C 14.06 8.03 14.06 8.02 14.06 8.01 C 14.06 8 14.06 7.99 14.06 7.97 C 14.06 7.97 14.06 7.96 14.06 7.96 C 14.05 7.95 14.05 7.95 14.05 7.95 L 14.05 7.95 C 14.05 7.94 14.05 7.94 14.05 7.93 C 12.9 5.28 10.48 3.5 8 3.5 C 5.53 3.5 3.1 5.28 1.95 7.94 C 1.95 7.94 1.95 7.94 1.95 7.95 C 1.94 7.95 1.94 7.95 1.94 7.95 C 1.94 7.97 1.94 7.98 1.94 7.99 V 8 C 1.94 8 1.94 8.01 1.94 8.02 C 1.94 8.02 1.94 8.02 1.94 8.02 C 1.94 8.03 1.94 8.03 1.94 8.04 C 1.94 8.04 1.95 8.05 1.95 8.05 C 1.95 8.06 1.95 8.06 1.95 8.06 C 3.11 10.72 5.53 12.5 8 12.5 C 10.48 12.5 12.9 10.72 14.05 8.07 C 14.05 8.06 14.05 8.06 14.05 8.05 C 14.05 8.05 14.05 8.05 14.05 8.05 Z" Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}" />
                            <Ellipse Canvas.Left="5.0"
                                     Canvas.Top="5.0"
                                     Width="6.0"
                                     Height="6.0"
                                     Stroke="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                                     StrokeDashCap="Flat"
                                     StrokeThickness="1.0" />
                            <Path x:Name="HiddenLine"
                                  Fill="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type ToggleButton}}, Path=Foreground}"
                                  StrokeDashCap="Flat"
                                  StrokeThickness="0.5"
                                  Visibility="Hidden">
                                <Path.Data>
                                    <PathGeometry Figures="M 2.91 1.89 L 2.9 1.89 L 2.89 1.88 C 2.61 1.68 2.22 1.71 1.97 1.96 C 1.68 2.24 1.68 2.7 1.96 2.98 L 13.01 14.04 L 13.01 14.04 L 13.02 14.05 L 13.09 14.11 L 13.1 14.11 L 13.11 14.12 C 13.39 14.32 13.78 14.29 14.03 14.04 C 14.32 13.76 14.32 13.3 14.04 13.02 L 2.99 1.96 L 2.99 1.96 L 2.98 1.95 L 2.91 1.89 Z" FillRule="Nonzero" />
                                </Path.Data>
                            </Path>
                        </Canvas>
                    </ToggleButton>
                    <Line x:Name="FocusedLine"
                          Grid.Column="0"
                          Grid.ColumnSpan="2"
                          Margin="1,0"
                          VerticalAlignment="Bottom"
                          RenderTransformOrigin=".5, .5"
                          Stretch="Fill"
                          Stroke="{DynamicResource Themes.Brushes.Primary}"
                          StrokeEndLineCap="Round"
                          StrokeStartLineCap="Round"
                          StrokeThickness="2"
                          UseLayoutRounding="True"
                          X1="0"
                          X2="1"
                          Y1="0"
                          Y2="0">
                        <Line.RenderTransform>
                            <ScaleTransform ScaleX="0" />
                        </Line.RenderTransform>
                    </Line>
                </Grid>
            </Border>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger SourceName="PlainTextBox" Property="IsFocused" Value="True">
                <Setter Property="Background" Value="Transparent" />
            </Trigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=(ui:PasswordBoxHelper.PasswordLength)}" Value="0">
                <Setter TargetName="PlaceHolderTextBlock" Property="Visibility" Value="Visible" />
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </DataTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition SourceName="PlainTextBox" Property="IsFocused" Value="False" />
                    <Condition Property="IsFocused" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="SwitchButton" Property="Visibility" Value="Hidden" />
            </MultiTrigger>
            <Trigger SourceName="SwitchButton" Property="IsChecked" Value="True">
                <Setter TargetName="PlainTextBox" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_ContentHost" Property="Visibility" Value="Hidden" />
                <Setter TargetName="HiddenLine" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger SourceName="SwitchButton" Property="IsMouseOver" Value="True">
                <Setter TargetName="SwitchButton" Property="Foreground" Value="{DynamicResource InputBox.Focus.BorderBrush}" />
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FocusedLine"
                                             Storyboard.TargetProperty="(Shape.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1"
                                             Duration="0:0:0.1">
                                <DoubleAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FocusedLine"
                                             Storyboard.TargetProperty="(Shape.RenderTransform).(ScaleTransform.ScaleX)"
                                             To="0"
                                             Duration="0:0:0.1">
                                <DoubleAnimation.EasingFunction>
                                    <CircleEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>

            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition SourceName="SwitchButton" Property="IsChecked" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
            </MultiTrigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition SourceName="SwitchButton" Property="IsChecked" Value="False" />
                    <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{DynamicResource Themes.Brushes.SecondaryFixed}" />
            </MultiTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- 常规 Password 样式 -->
    <Style TargetType="{x:Type PasswordBox}">
        <Setter Property="Padding" Value="4" />
        <Setter Property="BorderBrush" Value="{DynamicResource Themes.Brushes.Outline}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{DynamicResource Themes.Brushes.Secondary}" />
        <Setter Property="Foreground" Value="{DynamicResource Themes.Brushes.OnPrimary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Themes.Brushes.Primary}" />
        <Setter Property="CaretBrush" Value="White" />
        <Setter Property="PasswordChar" Value="●" />
        <Setter Property="ui:ControlHelper.CornerRadius" Value="2" />
        <Setter Property="InputMethod.IsInputMethodEnabled" Value="False" />
        <Setter Property="ui:PasswordBoxHelper.Attach" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template" Value="{StaticResource RegularPasswordBoxTemplate}" />
        <Style.Triggers>
            <!--<Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Themes.Brushes.SecondaryFixed}" />
            </Trigger>-->
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="Background" Value="#30000000" />
            </Trigger>
            <!--<Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource InputBox.Focus.BorderBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="BorderBrush" Value="{DynamicResource InputBox.Disable.BorderBrush}" />
                <Setter Property="Background" Value="{DynamicResource InputBox.Disable.Background}" />
            </Trigger>-->
        </Style.Triggers>
    </Style>
</ResourceDictionary>