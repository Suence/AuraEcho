<UserControl x:Class="PowerLab.Views.MarketplacePluginDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PowerLab.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PowerLab.PluginContracts.Models;assembly=PowerLab.PluginContracts"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:selectors="clr-namespace:PowerLab.Selectors"
             xmlns:sv="clr-namespace:PowerLab.Services"
             xmlns:ui="http://ui.powerlab.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             Padding="0,36,0,0"
             d:DataContext="{d:DesignInstance Type=viewmodels:MarketplacePluginDetailsViewModel}"
             d:DesignHeight="615"
             d:DesignWidth="825"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource Themes.Brushes.Background}"
             Foreground="#EFEFEF"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ui:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <converters:FileIdToUrlConverter x:Key="FileIdToUrl" />
        <DataTemplate x:Key="NotInstalledTemplate" DataType="{x:Type models:TransferStatus}">
            <Button Width="200"
                    Height="48"
                    Padding="16,0"
                    HorizontalContentAlignment="Left"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.InstallCommand}"
                    Content="INSTALL"
                    FontSize="16"
                    Style="{DynamicResource PrimaryButtonStyle}" />
        </DataTemplate>
        <DataTemplate x:Key="DownloadingTemplate" DataType="{x:Type models:TransferStatus}">
            <Border Width="200"
                    Height="48"
                    Background="#10FFFFFF"
                    CornerRadius="4">
                <DockPanel LastChildFill="True">
                    <ProgressBar DockPanel.Dock="Top" Value="{Binding Source={StaticResource BindingProxy}, Path=Data.MarketPlugin.InstallContext.Progress, Mode=OneWay}" d:Value="80"/>
                    <TextBlock Margin="16,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="14"
                               d:Text="正在下载(87.23%)"
                               Text="{Binding Source={StaticResource BindingProxy}, Path=Data.MarketPlugin.InstallContext.Progress, StringFormat=正在下载({0:F2}%)}" />
                </DockPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InstallingTemplate" DataType="{x:Type models:TransferStatus}">
            <Border Width="200"
                    Height="48"
                    Background="#10FFFFFF"
                    CornerRadius="4">
                <DockPanel LastChildFill="True">
                    <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" />
                    <TextBlock Margin="16,0,0,0"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Text="正在安装..." />
                </DockPanel>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="InstalledTemplate" DataType="{x:Type models:TransferStatus}">
            <Button Width="200"
                    Height="48"
                    Padding="16,0"
                    HorizontalContentAlignment="Left"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.OpenPluginCommand}"
                    Content="OPEN"
                    FontSize="16"
                    Style="{DynamicResource PrimaryButtonStyle}" />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <ScrollViewer Padding="32">
            <StackPanel MaxWidth="1200">
                <DockPanel Margin="0,0,0,16" LastChildFill="True">
                    <Border Width="80"
                            Height="80"
                            Margin="0,0,16,0"
                            CornerRadius="8"
                            DockPanel.Dock="Left">
                        <Border.Background>
                            <ImageBrush d:ImageSource="/Assets/Icons/PowerLab.ico" ImageSource="{Binding MarketPlugin.PluginInfo.IconFileId, Converter={StaticResource FileIdToUrl}}" />
                        </Border.Background>
                    </Border>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,4"
                                   d:Text="Plugin Name"
                                   FontSize="24"
                                   Text="{Binding MarketPlugin.PluginInfo.DisplayName}" />
                        <TextBlock d:Text="Plugin author"
                                   FontSize="16"
                                   Text="{Binding MarketPlugin.PluginInfo.Author}" />
                    </StackPanel>
                </DockPanel>
                <TextBlock Margin="0,0,0,16"
                           FontSize="14"
                           Text="{Binding MarketPlugin.PluginInfo.Description}" />
                <ContentControl Margin="0,0,0,24"
                                HorizontalAlignment="Left"
                                d:ContentTemplate="{StaticResource DownloadingTemplate}"
                                Content="{Binding MarketPlugin.InstallContext.Status}">
                    <ContentControl.ContentTemplateSelector>
                        <selectors:MarketPluginStateTemplateSelector DownloadingTemplate="{StaticResource DownloadingTemplate}"
                                                                     InstalledTemplate="{StaticResource InstalledTemplate}"
                                                                     InstallingTemplate="{StaticResource InstallingTemplate}"
                                                                     NotInstalledTemplate="{StaticResource NotInstalledTemplate}" />
                    </ContentControl.ContentTemplateSelector>
                </ContentControl>
                <!--<TextBlock Text="{Binding MarketPlugin.InstallContext.Progress, StringFormat=Installing {0:F2}%}"
                           Margin="0, 0, 0, 4" />
                <ProgressBar Width="200"
                             Margin="0,0,0,4"
                             HorizontalAlignment="Left"
                             Maximum="100"
                             Minimum="0"
                             Value="{Binding MarketPlugin.InstallContext.Progress, Mode=OneWay}" />
                <Button Padding="16,0"
                        HorizontalAlignment="Left"
                        Width="200"
                        Height="48"
                        Margin="0, 0, 0, 24"
                        HorizontalContentAlignment="Left"
                        Command="{Binding InstallCommand}"
                        Content="{Binding MarketPlugin.InstallContext.Status}"
                        FontSize="16"
                        Style="{DynamicResource PrimaryButtonStyle}" />
                <Grid Width="200"
                      Height="48"
                      Margin="0,0,0,24"
                      Visibility="Collapsed"
                      HorizontalAlignment="Left">
                    <i:Interaction.Triggers>
                        <i:DataTrigger Binding="{Binding Plugin.IsInstalled}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="InstallButton"
                                                    Value="{x:Static Visibility.Hidden}" />
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="OpenButton"
                                                    Value="{x:Static Visibility.Visible}" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding Plugin.IsInstalled}"
                                       Value="False">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="InstallButton"
                                                    Value="{x:Static Visibility.Visible}" />
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="OpenButton"
                                                    Value="{x:Static Visibility.Hidden}" />
                        </i:DataTrigger>
                    </i:Interaction.Triggers>
                    <Button x:Name="InstallButton"
                            Padding="16,0"
                            HorizontalContentAlignment="Left"
                            Command="{Binding InstallCommand}"
                            Content="INSTALL"
                            FontSize="16"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button x:Name="OpenButton"
                            Padding="16,0"
                            HorizontalContentAlignment="Left"
                            Command="{Binding OpenPluginCommand}"
                            Content="OPEN"
                            FontSize="16"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                </Grid>-->

                <Border Margin="0,0,0,16"
                        Background="{DynamicResource Themes.Brushes.SecondaryContainer}"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Margin="16"
                                   FontSize="14"
                                   Text="DESCRIPTION" />
                        <Line Stretch="Fill"
                              Stroke="{DynamicResource Themes.Brushes.OnSurface}"
                              X1="0"
                              X2="1"
                              Y1="0"
                              Y2="0" />
                        <TextBlock Margin="16"
                                   d:Text="这是此扩展的描述文本"
                                   Text="{Binding MarketPlugin.PluginInfo.Description}" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource Themes.Brushes.SecondaryContainer}" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Margin="16"
                                   FontSize="14"
                                   Text="OTHER INFO" />
                        <Line Stretch="Fill"
                              Stroke="{DynamicResource Themes.Brushes.OnSurface}"
                              X1="0"
                              X2="1"
                              Y1="0"
                              Y2="0" />
                        <WrapPanel Margin="16" Orientation="Horizontal">
                            <DockPanel Width="200"
                                       Margin="0,0,0,24"
                                       LastChildFill="True">
                                <Canvas Width="24"
                                        Height="24"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        DockPanel.Dock="Left">
                                    <Path Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L10.11,5.22L16,8.61L17.96,7.5L12,4.15M6.04,7.5L12,10.85L13.96,9.75L8.08,6.35L6.04,7.5M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z" Fill="{DynamicResource Themes.Brushes.OnSurface}" />
                                </Canvas>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8" Text="AUTHOR" />
                                    <TextBlock d:Text="plugin author" Text="{Binding MarketPlugin.PluginInfo.Author}" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Width="200" LastChildFill="True">
                                <Canvas Width="24"
                                        Height="24"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        DockPanel.Dock="Left">
                                    <Path Data="M12,6V9L16,5L12,1V4A8,8 0 0,0 4,12C4,13.57 4.46,15.03 5.24,16.26L6.7,14.8C6.25,13.97 6,13 6,12A6,6 0 0,1 12,6M18.76,7.74L17.3,9.2C17.74,10.04 18,11 18,12A6,6 0 0,1 12,18V15L8,19L12,23V20A8,8 0 0,0 20,12C20,10.43 19.54,8.97 18.76,7.74Z" Fill="{DynamicResource Themes.Brushes.OnSurface}" />
                                </Canvas>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8" Text="LATEST UPDATE" />
                                    <TextBlock d:Text="1970/1/1" Text="{Binding LatestVersionInfo.CreateTime, StringFormat={}{0:yyyy/MM/dd}}" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Width="200" LastChildFill="True">
                                <Canvas Width="24"
                                        Height="24"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        DockPanel.Dock="Left">
                                    <Path Data="M9,7V17H11V12L13,17H15V7H13V12L11,7H9M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2Z" Fill="{DynamicResource Themes.Brushes.OnSurface}" />
                                </Canvas>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8" Text="VERSION" />
                                    <TextBlock d:Text="1.0.1" Text="{Binding LatestVersionInfo.Version}" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Width="200" LastChildFill="True">
                                <Canvas Width="24"
                                        Height="24"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        DockPanel.Dock="Left">
                                    <Path Data="M5,4V6H19V4H5M5,14H9V20H15V14H19L12,7L5,14Z" Fill="{DynamicResource Themes.Brushes.OnSurface}" />
                                </Canvas>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8" Text="PUBLISH" />
                                    <TextBlock d:Text="1970/1/1" Text="{Binding MarketPlugin.PluginInfo.CreateTime, StringFormat={}{0:yyyy/MM/dd}}" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Width="200" LastChildFill="True">
                                <Canvas Width="24"
                                        Height="24"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Top"
                                        DockPanel.Dock="Left">
                                    <Path Data="M18,8H16V4H18M15,8H13V4H15M12,8H10V4H12M18,2H10L4,8V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V4A2,2 0 0,0 18,2Z" Fill="{DynamicResource Themes.Brushes.OnSurface}" />
                                </Canvas>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8" Text="PACKAGE SIZE" />
                                    <TextBlock d:Text="2.3 MB" Text="{Binding LatestVersionInfo.Size, StringFormat={}{0} Byte}" />
                                </StackPanel>
                            </DockPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
