<UserControl x:Class="PowerLab.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cc="clr-namespace:PowerLab.Core.Constants;assembly=PowerLab.Core"
             xmlns:cm="clr-namespace:PowerLab.Host.Core.Models;assembly=PowerLab.Host.Core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:HomepageViewModel}"
             d:DesignHeight="290"
             d:DesignWidth="495"
             d:Background="#666666"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPluginsCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <DataTemplate x:Key="PluginTemplate" DataType="{x:Type cm:PluginMetadata}">
            <Button d:Content="Plugin"
                    Height="30"
                    BorderThickness="0"
                    Margin="0, 0, 0, 1"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SwitchPluginCommand}"
                    CommandParameter="{Binding}"
                    Content="{Binding Name}" />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Width="141" Background="#33000000">
            <TextBlock Text="ALL PLUGINS" Margin="8, 36, 0, 8" FontSize="16" />
            <ItemsControl ItemTemplate="{StaticResource PluginTemplate}" ItemsSource="{Binding Plugins}">
                <d:ItemsControl.ItemsSource>
                    <x:Array Type="{x:Type cm:PluginMetadata}">
                        <cm:PluginMetadata />
                        <cm:PluginMetadata />
                        <cm:PluginMetadata />
                    </x:Array>
                </d:ItemsControl.ItemsSource>
            </ItemsControl>
        </StackPanel>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="{x:Static cc:HostRegionNames.PluginContentRegion}" />
    </Grid>
</UserControl>
