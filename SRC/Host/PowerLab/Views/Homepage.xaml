<UserControl x:Class="PowerLab.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cc="clr-namespace:PowerLab.Core.Constants;assembly=PowerLab.Core"
             xmlns:cm="clr-namespace:PowerLab.Host.Core.Models;assembly=PowerLab.Host.Core"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:Background="#666666"
             d:DataContext="{d:DesignInstance Type=viewmodels:HomepageViewModel}"
             d:DesignHeight="290"
             d:DesignWidth="495"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPluginsCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <CollectionViewSource x:Key="EnabledPluginsView"
                              Filter="EnabledPluginsFilter"
                              Source="{Binding Plugins}" />
        <DataTemplate x:Key="PluginTemplate" DataType="{x:Type cm:PluginRegistry}">
            <Button Height="30"
                    Margin="0,0,0,1"
                    d:Content="Plugin"
                    BorderThickness="0"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SwitchPluginCommand}"
                    CommandParameter="{Binding}"
                    Content="{Binding Name}" />
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    Width="141"
                    Background="#33000000">
            <Button Height="30"
                    Margin="0,36,0,16"
                    BorderThickness="0"
                    Command="{Binding NavigationToDashboardCommand}"
                    Content="DASHBOARD" />

            <ItemsControl ItemTemplate="{StaticResource PluginTemplate}" ItemsSource="{Binding Source={StaticResource EnabledPluginsView}}">
                <d:ItemsControl.ItemsSource>
                    <x:Array Type="{x:Type cm:PluginRegistry}">
                        <cm:PluginRegistry />
                        <cm:PluginRegistry />
                        <cm:PluginRegistry />
                    </x:Array>
                </d:ItemsControl.ItemsSource>
            </ItemsControl>
        </StackPanel>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="{x:Static cc:HostRegionNames.PluginContentRegion}" />
    </Grid>
</UserControl>
