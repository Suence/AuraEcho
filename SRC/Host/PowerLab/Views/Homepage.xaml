<UserControl x:Class="PowerLab.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cc="clr-namespace:PowerLab.PluginContracts.Constants;assembly=PowerLab.PluginContracts"
             xmlns:cm="clr-namespace:PowerLab.Core.Models;assembly=PowerLab.Core"
             xmlns:converters="clr-namespace:PowerLab.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:Background="{DynamicResource Themes.Brushes.Background}"
             d:DataContext="{d:DesignInstance Type=viewmodels:HomepageViewModel}"
             d:DesignHeight="355"
             d:DesignWidth="535"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy"
                               Data="{Binding}" />
        <CollectionViewSource x:Key="EnabledPluginsView"
                              Filter="EnabledPluginsFilter"
                              IsLiveSortingRequested="True"
                              Source="{Binding Plugins}" />
        <DataTemplate x:Key="PluginTemplate"
                      DataType="{x:Type cm:PluginRegistry}">

            <Button Width="80"
                    Height="80"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SwitchPluginCommand}"
                    CommandParameter="{Binding}"
                    FontSize="12"
                    Style="{DynamicResource IconButtonStyle}">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SwitchPluginCommand}"
                                  CommandParameter="{Binding}"
                                  Header="OPEN" />
                    </ContextMenu>
                </Button.ContextMenu>
                <DockPanel LastChildFill="True">
                    <Rectangle Width="48"
                               Height="48"
                               Margin="0,0,0,4"
                               DockPanel.Dock="Top"
                               RadiusX="4"
                               RadiusY="4">
                        <Rectangle.Fill>
                            <ImageBrush ImageSource="{Binding Path=., Converter={converters:PluginIconConverter}}" />
                        </Rectangle.Fill>
                    </Rectangle>
                    <TextBlock VerticalAlignment="Center"
                               d:Text="Plugin Name"
                               Text="{Binding Manifest.PluginName}" />
                </DockPanel>
            </Button>
        </DataTemplate>
        <CollectionViewSource x:Key="PluginsSource"
                              Source="{Binding Plugins}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <ItemsControl Grid.Row="1"
                      Margin="24, 12, 24, 24"
                      ItemTemplate="{StaticResource PluginTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True"
                               Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemsSource>
                <CompositeCollection>
                    <CollectionContainer d:Collection="{d:SampleData ItemCount=7}"
                                         Collection="{Binding Source={StaticResource PluginsSource}}" />
                    <Button Width="80"
                            Height="80"
                            Command="{Binding NavigationToPluginsMarketplaceCommand}"
                            FontSize="12"
                            Style="{DynamicResource IconButtonStyle}">
                        <DockPanel LastChildFill="True">
                            <Viewbox Width="48"
                                     Height="48"
                                     DockPanel.Dock="Top">
                                <Canvas Width="24"
                                        Height="24">
                                    <Path Data="M12,13A5,5 0 0,1 7,8H9A3,3 0 0,0 12,11A3,3 0 0,0 15,8H17A5,5 0 0,1 12,13M12,3A3,3 0 0,1 15,6H9A3,3 0 0,1 12,3M19,6H17A5,5 0 0,0 12,1A5,5 0 0,0 7,6H5C3.89,6 3,6.89 3,8V20A2,2 0 0,0 5,22H19A2,2 0 0,0 21,20V8C21,6.89 20.1,6 19,6Z"
                                          Fill="#AAAAAA" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Source={StaticResource R}, Path=Labels.PluginsMarketplace}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Button>
                    <Button Width="80"
                            Height="80"
                            Command="{Binding NavigationToSettingsCommand}"
                            FontSize="12"
                            Style="{DynamicResource IconButtonStyle}">
                        <DockPanel LastChildFill="True">
                            <Viewbox Width="48"
                                     Height="48"
                                     DockPanel.Dock="Top">
                                <Canvas Width="24"
                                        Height="24">
                                    <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"
                                          Fill="#AAAAAA" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       d:Text="Plugin Name"
                                       Text="{Binding Source={StaticResource R}, Path=Labels.Settings}"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>
                    </Button>
                </CompositeCollection>
            </ItemsControl.ItemsSource>
        </ItemsControl>
    </Grid>
</UserControl>
