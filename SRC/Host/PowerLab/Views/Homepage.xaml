<UserControl x:Class="PowerLab.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cc="clr-namespace:PowerLab.PluginContracts.Constants;assembly=PowerLab.PluginContracts"
             xmlns:cm="clr-namespace:PowerLab.Core.Models;assembly=PowerLab.Core"
             xmlns:converters="clr-namespace:PowerLab.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:Background="#666666"
             d:DataContext="{d:DesignInstance Type=viewmodels:HomepageViewModel}"
             d:DesignHeight="290"
             d:DesignWidth="495"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <CollectionViewSource x:Key="EnabledPluginsView"
                              Filter="EnabledPluginsFilter"
                              IsLiveSortingRequested="True"
                              Source="{Binding Plugins}" />
        <DataTemplate x:Key="PluginTemplate" DataType="{x:Type cm:PluginRegistry}">
            <Button Margin="0,0,0,1"
                    Padding="8"
                    HorizontalContentAlignment="Stretch"
                    d:Content="Plugin"
                    powerlab:ControlHelper.CornerRadius="0"
                    BorderThickness="0"
                    Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SwitchPluginCommand}"
                    CommandParameter="{Binding}">
                <DockPanel LastChildFill="True">
                    <Image Width="24"
                           Height="24"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Source="{Binding Path=., Converter={converters:PluginIconConverter}}" />
                    <TextBlock VerticalAlignment="Center"
                               d:Text="Plugin Name"
                               Text="{Binding Manifest.PluginName}" />
                </DockPanel>
            </Button>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0"
              Width="141"
              Background="#33000000">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <Button Height="30"
                        Margin="0,36,0,16"
                        powerlab:ControlHelper.CornerRadius="0"
                        BorderThickness="0"
                        Command="{Binding NavigationToDashboardCommand}"
                        Content="DASHBOARD" />

                <ItemsControl ItemTemplate="{StaticResource PluginTemplate}" ItemsSource="{Binding Source={StaticResource EnabledPluginsView}}">
                    <d:ItemsControl.ItemsSource>
                        <x:Array Type="{x:Type cm:PluginRegistry}">
                            <cm:PluginRegistry />
                            <cm:PluginRegistry />
                            <cm:PluginRegistry />
                        </x:Array>
                    </d:ItemsControl.ItemsSource>
                </ItemsControl>
            </StackPanel>
            <StackPanel Grid.Row="1">
                <Button Grid.Row="1"
                        Height="30"
                        powerlab:ControlHelper.CornerRadius="0"
                        BorderThickness="0"
                        Command="{Binding NavigationToPluginsMarketplaceCommand}"
                        Content="{Binding Source={StaticResource R}, Path=Labels.PluginsMarketplace}" />
                <Button Grid.Row="1"
                        Height="30"
                        powerlab:ControlHelper.CornerRadius="0"
                        BorderThickness="0"
                        Command="{Binding NavigationToSettingsCommand}"
                        Content="{Binding Source={StaticResource R}, Path=Labels.Settings}" />
            </StackPanel>
        </Grid>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="{x:Static cc:HostRegionNames.HomeContentRegion}" />
    </Grid>
</UserControl>
