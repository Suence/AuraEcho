<ResourceDictionary x:Class="OTLog.Views.NotifyIcon"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:constants="clr-namespace:PowerLab.PluginContracts.Constants;assembly=PowerLab.PluginContracts"
                    xmlns:prism="http://prismlibrary.com/"
                    xmlns:tb="http://www.hardcodet.net/taskbar"
                    xmlns:vm="clr-namespace:PowerLab.ViewModels">
    <ContextMenu x:Key="SysTrayMenu" x:Shared="false">
        <!--<MenuItem Header="个性化设置"
                  Command="{Binding GoToTargetViewCommand}"
                  CommandParameter="{x:Static constants:ViewNames.Settings}"/>-->
        <Separator />
        <!--<MenuItem Header="关于"
                  Command="{Binding GoToTargetViewCommand}"
                  CommandParameter="{x:Static constants:ViewNames.About}"/>-->
        <MenuItem Command="{Binding ExitApplicationCommand}" Header="退出" />
    </ContextMenu>

    <tb:TaskbarIcon x:Key="NotifyIcon"
                    ContextMenu="{StaticResource SysTrayMenu}"
                    DoubleClickCommand="{Binding ShowWindowCommand}"
                    IconSource="/Assets/Icons/PowerLab.ico"
                    ToolTipText="PowerLab v1.0.0">
        <!--<tb:TaskbarIcon.DataContext>
            <vm:NotifyIconViewModel />
        </tb:TaskbarIcon.DataContext>-->
    </tb:TaskbarIcon>

</ResourceDictionary>