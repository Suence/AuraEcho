<UserControl x:Class="PowerLab.Views.PluginsDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hostModels="clr-namespace:PowerLab.Host.Core.Models;assembly=PowerLab.Host.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:PluginsDashboardViewModel}"
             d:DesignHeight="425"
             d:DesignWidth="495"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">

    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <DataTemplate x:Key="PluginTemplate" DataType="{x:Type hostModels:PluginRegistry}">
            <Border Padding="8"
                    Background="#33333333"
                    CornerRadius="4">
                <Grid>
                    <TextBlock HorizontalAlignment="Left" Text="{Binding Name}" />
                    <CheckBox HorizontalAlignment="Right" IsChecked="{Binding IsEnabled}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Checked">
                                <i:InvokeCommandAction Command="{Binding Source={StaticResource BindingProxy}, Path=Data.EnablePluginCommand}" CommandParameter="{Binding}" />
                            </i:EventTrigger>
                            <i:EventTrigger EventName="Unchecked">
                                <i:InvokeCommandAction Command="{Binding Source={StaticResource BindingProxy}, Path=Data.DisablePluginCommand}" CommandParameter="{Binding}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </CheckBox>
                </Grid>
            </Border>
        </DataTemplate>
        <Style x:Key="PluginContainerStyle" TargetType="{x:Type ContentPresenter}">
            <Setter Property="Margin" Value="4" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="0,36,0,0">
        <StackPanel Margin="24, 0, 24, 24">
            <TextBlock Margin="0,0,0,24"
                       HorizontalAlignment="Left"
                       FontSize="20"
                       Text="DASHBOARD" />
            <TextBlock Margin="0,0,0,8"
                       FontSize="16"
                       Text="Pending Plugins" />
            <ItemsControl Margin="0,0,0,16"
                          d:ItemsSource="{d:SampleData ItemCount=3}"
                          ItemContainerStyle="{StaticResource PluginContainerStyle}"
                          ItemTemplate="{StaticResource PluginTemplate}"
                          ItemsSource="{Binding PendingPlugins, Mode=OneWay}" />
            <TextBlock Margin="0,0,0,8"
                       FontSize="16"
                       Text="Enabled Plugins" />
            <ItemsControl Margin="0,0,0,16"
                          d:ItemsSource="{d:SampleData ItemCount=3}"
                          ItemContainerStyle="{StaticResource PluginContainerStyle}"
                          ItemTemplate="{StaticResource PluginTemplate}"
                          ItemsSource="{Binding EnabledPlugins, Mode=OneWay}" />
            <TextBlock Margin="0,0,0,8"
                       FontSize="16"
                       Text="Disabled Plugins" />
            <ItemsControl d:ItemsSource="{d:SampleData ItemCount=3}"
                          ItemContainerStyle="{StaticResource PluginContainerStyle}"
                          ItemTemplate="{StaticResource PluginTemplate}"
                          ItemsSource="{Binding DisabledPlugins, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
