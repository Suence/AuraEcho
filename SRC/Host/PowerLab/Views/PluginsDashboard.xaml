<UserControl x:Class="PowerLab.Views.PluginsDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PowerLab.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:models="clr-namespace:PowerLab.Core.Models;assembly=PowerLab.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:PluginsDashboardViewModel}"
             d:DesignHeight="425"
             d:DesignWidth="495"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">

    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <DataTemplate x:Key="PluginTemplate" DataType="{x:Type models:PluginRegistry}">
            <Border Padding="8"
                    Background="#33333333"
                    CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Width="50"
                           Margin="0, 0, 4, 0"
                           Height="50" Source="{Binding Path=., Converter={converters:PluginIconConverter}}"/>
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock HorizontalAlignment="Left" Grid.Row="0" FontWeight="Bold" Text="{Binding Manifest.PluginName}" />
                        <TextBlock Grid.Row="1" Text="{Binding Manifest.Description}"/>
                        <DockPanel Grid.Row="2" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding Manifest.Author}"/>
                            <StackPanel DockPanel.Dock="Right"
                                    VerticalAlignment="Bottom"
                                    Orientation="Horizontal">
                                <TextBlock Margin="0,0,4,0" d:Text="已启用">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{converters:PluginStatusTextConverter}">
                                            <Binding Path="Status" />
                                            <Binding Path="PlanStatus" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Button x:Name="PluginPlanButton"
                                    Padding="8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Content="...">
                                    <Button.ContextMenu>
                                        <ContextMenu x:Name="PluginContextMenu" StaysOpen="False">
                                            <MenuItem x:Name="EnablePluginMenuItem"
                                                  Command="{Binding Source={StaticResource BindingProxy}, Path=Data.PlanEnablePluginCommand}"
                                                  CommandParameter="{Binding}"
                                                  Header="ENABLE">
                                                <i:Interaction.Triggers>
                                                    <i:DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginStatus.Enabled}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginStatus.Disabled}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.EnablePending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.DisablePending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>

                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.None}">
                                                        <i:Interaction.Behaviors>
                                                            <i:ConditionBehavior>
                                                                <i:ConditionalExpression>
                                                                    <i:ComparisonCondition LeftOperand="{Binding Status}"
                                                                                       Operator="Equal"
                                                                                       RightOperand="{x:Static models:PluginStatus.Enabled}" />
                                                                </i:ConditionalExpression>
                                                            </i:ConditionBehavior>
                                                        </i:Interaction.Behaviors>
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.None}">
                                                        <i:Interaction.Behaviors>
                                                            <i:ConditionBehavior>
                                                                <i:ConditionalExpression>
                                                                    <i:ComparisonCondition LeftOperand="{Binding Status}"
                                                                                       Operator="Equal"
                                                                                       RightOperand="{x:Static models:PluginStatus.Disabled}" />
                                                                </i:ConditionalExpression>
                                                            </i:ConditionBehavior>
                                                        </i:Interaction.Behaviors>
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                </i:Interaction.Triggers>
                                            </MenuItem>

                                            <MenuItem x:Name="DisablePluginMenuItem"
                                                  Command="{Binding Source={StaticResource BindingProxy}, Path=Data.PlanDisablePluginCommand}"
                                                  CommandParameter="{Binding}"
                                                  Header="DISABLE">
                                                <i:Interaction.Triggers>
                                                    <i:DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginStatus.Enabled}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginStatus.Disabled}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.EnablePending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.DisablePending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>

                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.None}">
                                                        <i:Interaction.Behaviors>
                                                            <i:ConditionBehavior>
                                                                <i:ConditionalExpression>
                                                                    <i:ComparisonCondition LeftOperand="{Binding Status}"
                                                                                       Operator="Equal"
                                                                                       RightOperand="{x:Static models:PluginStatus.Enabled}" />
                                                                </i:ConditionalExpression>
                                                            </i:ConditionBehavior>
                                                        </i:Interaction.Behaviors>
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.None}">
                                                        <i:Interaction.Behaviors>
                                                            <i:ConditionBehavior>
                                                                <i:ConditionalExpression>
                                                                    <i:ComparisonCondition LeftOperand="{Binding Status}"
                                                                                       Operator="Equal"
                                                                                       RightOperand="{x:Static models:PluginStatus.Disabled}" />
                                                                </i:ConditionalExpression>
                                                            </i:ConditionBehavior>
                                                        </i:Interaction.Behaviors>
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>

                                                </i:Interaction.Triggers>
                                            </MenuItem>
                                            <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.PlanUninstallPluginCommand}"
                                                  CommandParameter="{Binding}"
                                                  Header="UNINSTALL">
                                                <i:Interaction.Triggers>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}"
                                                               Comparison="NotEqual"
                                                               Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                </i:Interaction.Triggers>
                                            </MenuItem>
                                            <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.CancelUninstallPluginCommand}"
                                                  CommandParameter="{Binding}"
                                                  Header="CANCEL UNINSTALL">
                                                <i:Interaction.Triggers>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}" Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                                                    </i:DataTrigger>
                                                    <i:DataTrigger Binding="{Binding PlanStatus}"
                                                               Comparison="NotEqual"
                                                               Value="{x:Static models:PluginPlanStatus.UninstallPending}">
                                                        <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Collapsed}" />
                                                    </i:DataTrigger>
                                                </i:Interaction.Triggers>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="Click">
                                            <i:ChangePropertyAction PropertyName="IsOpen"
                                                                TargetName="PluginContextMenu"
                                                                Value="True" />
                                        </i:EventTrigger>
                                        <i:EventTrigger EventName="Loaded">
                                            <i:ChangePropertyAction PropertyName="DataContext"
                                                                TargetName="PluginContextMenu"
                                                                Value="{Binding}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
        <Style x:Key="PluginContainerStyle" TargetType="{x:Type ContentPresenter}">
            <Setter Property="Margin" Value="4" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="0,36,0,0">
        <StackPanel Margin="24,0,24,24">
            <TextBlock Margin="0,0,0,24"
                       HorizontalAlignment="Left"
                       FontSize="20"
                       Text="DASHBOARD" />

            <TextBlock Margin="0,0,0,8"
                       FontSize="16"
                       Text="Enabled Plugins" />
            <ItemsControl Margin="0,0,0,16"
                          d:ItemsSource="{d:SampleData ItemCount=3}"
                          ItemContainerStyle="{StaticResource PluginContainerStyle}"
                          ItemTemplate="{StaticResource PluginTemplate}"
                          ItemsSource="{Binding EnabledPlugins, Mode=OneWay}" />
            <TextBlock Margin="0,0,0,8"
                       FontSize="16"
                       Text="Disabled Plugins" />
            <ItemsControl d:ItemsSource="{d:SampleData ItemCount=3}"
                          ItemContainerStyle="{StaticResource PluginContainerStyle}"
                          ItemTemplate="{StaticResource PluginTemplate}"
                          ItemsSource="{Binding DisabledPlugins, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
