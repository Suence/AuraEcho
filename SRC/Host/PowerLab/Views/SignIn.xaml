<UserControl x:Class="PowerLab.Views.SignIn"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cc="clr-namespace:PowerLab.PluginContracts.Constants;assembly=PowerLab.PluginContracts"
             xmlns:cm="clr-namespace:PowerLab.Core.Models;assembly=PowerLab.Core"
             xmlns:converters="clr-namespace:PowerLab.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PowerLab.Core.Models;assembly=PowerLab.Core"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:ui="http://ui.powerlab.com/"
             xmlns:viewmodels="clr-namespace:PowerLab.ViewModels"
             d:Background="{DynamicResource Themes.Brushes.Background}"
             d:DataContext="{d:DesignInstance Type=viewmodels:SignInViewModel}"
             d:DesignHeight="655"
             d:DesignWidth="835"
             d:Foreground="{DynamicResource Themes.Brushes.OnBackground}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d">
    <Grid Margin="0,36,0,0">
        <Border Width="450"
                Height="350"
                Padding="32"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#10FFFFFF"
                CornerRadius="8">
            <Grid>

                <StackPanel>
                    <TextBlock Margin="0,0,0,24"
                               FontSize="30"
                               Text="SIGN IN TO POWERLAB." />
                    <TextBox Height="40"
                             Margin="0,0,0,16"
                             Padding="16,0"
                             ui:ControlHelper.PlaceHolder="USERNAME"
                             FontSize="20"
                             Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />
                    <PasswordBox Height="40"
                                 Padding="16,0"
                                 ui:ControlHelper.PlaceHolder="PASSWORD"
                                 ui:PasswordBoxHelper.Password="{Binding Password, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 FontSize="20" />
                </StackPanel>
                <StackPanel VerticalAlignment="Bottom">
                    <Button Height="50"
                            Margin="0,0,0,8"
                            Command="{Binding SignInCommand}"
                            Content="SIGN IN"
                            FontSize="20"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <TextBlock>
                        <Hyperlink Command="{Binding NavigationToSignUpCommand}">NO ACCOUNT? CREATE NOW</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
