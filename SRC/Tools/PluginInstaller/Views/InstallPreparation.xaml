<UserControl x:Class="PluginInstaller.Views.InstallPreparation"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewmodels="clr-namespace:PluginInstaller.ViewModels"
             Background="#212121"
             Foreground="#EFEFEF"
             d:DataContext="{d:DesignInstance Type=viewmodels:InstallPreparationViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" d:DesignHeight="125" d:DesignWidth="285">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadPluginCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="{Binding PluginManifest.PluginName, StringFormat=Name: {0}}" d:Text="Name: PluginName"/>
            <TextBlock Text="{Binding PluginManifest.Version, StringFormat=Version: {0}}" d:Text="Version: 1.0.0"/>
            <TextBlock Text="{Binding PluginManifest.Description, StringFormat=Description: {0}}" d:Text="Description: This is a plix plugin." />
        </StackPanel>
        <Button Content="Install" Command="{Binding BeginInstallCommand}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Padding="16, 4"/>
    </Grid>
</UserControl>
