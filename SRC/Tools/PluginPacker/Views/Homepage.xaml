<UserControl x:Class="PluginPacker.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="clr-namespace:PluginPacker.Behaviors"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PluginPacker.Models"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:selector="clr-namespace:PluginPacker.Selector"
             xmlns:system="clr-namespace:System;assembly=netstandard"
             xmlns:viewmodels="clr-namespace:PluginPacker.ViewModels"
             av:DataContext="{av:DesignInstance Type=viewmodels:HomepageViewModel}"
             av:DesignHeight="550"
             av:DesignWidth="895"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#212121"
             Foreground="#EFEFEF"
             mc:Ignorable="av">
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <HierarchicalDataTemplate x:Key="PluginFolderTemplate"
                                  DataType="{x:Type models:PluginFolder}"
                                  ItemsSource="{Binding Children}">
            <Grid AllowDrop="True"
                  Background="DeepSkyBlue"
                  DragDrop.PreviewDragOver="PluginFolder_DropOver"
                  Drop="PluginFolder_Drop">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.RemoveFolderCommand}"
                                  CommandParameter="{Binding}"
                                  Header="DELETE" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock HorizontalAlignment="Left" Text="{Binding Name, StringFormat=FOLDER: {0}}" />
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                    <Button Margin="0,0,4,0"
                            Padding="16,4"
                            VerticalAlignment="Center"
                            Command="{Binding Source={StaticResource BindingProxy}, Path=Data.AddPluginFileCommand}"
                            CommandParameter="{Binding}">
                        <Viewbox Width="16"
                                 Height="16"
                                 Margin="0,0,4,0">
                            <Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                    Width="24"
                                    Height="24">
                                <Path Data="M14 2H6C4.89 2 4 2.89 4 4V20C4 21.11 4.89 22 6 22H13.81C13.28 21.09 13 20.05 13 19C13 15.69 15.69 13 19 13C19.34 13 19.67 13.03 20 13.08V8L14 2M13 9V3.5L18.5 9H13M23 20H20V23H18V20H15V18H18V15H20V18H23V20Z" Fill="#000000" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Padding="16,4"
                            VerticalAlignment="Center"
                            Command="{Binding Source={StaticResource BindingProxy}, Path=Data.AddPluginFolderCommand}"
                            CommandParameter="{Binding}">
                        <Viewbox Width="16"
                                 Height="16"
                                 Margin="0,0,4,0">
                            <Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                    Width="24"
                                    Height="24">
                                <Path Data="M13 19C13 19.34 13.04 19.67 13.09 20H4C2.9 20 2 19.11 2 18V6C2 4.89 2.89 4 4 4H10L12 6H20C21.1 6 22 6.89 22 8V13.81C21.12 13.3 20.1 13 19 13C15.69 13 13 15.69 13 19M20 18V15H18V18H15V20H18V23H20V20H23V18H20Z" Fill="#000000" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate x:Key="PluginFileTemplate" DataType="{x:Type models:PluginFile}">
            <Grid AllowDrop="True"
                  DragDrop.PreviewDragOver="PluginFolder_DropOver"
                  Drop="PluginFolder_Drop">
                <Grid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SetEntryFileCommand}"
                                  CommandParameter="{Binding}"
                                  Header="SET ENTRY" />
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.RemoveFileCommand}"
                                  CommandParameter="{Binding}"
                                  Header="DELETE" />
                    </ContextMenu>
                </Grid.ContextMenu>
                <TextBlock Text="{Binding Name, StringFormat=FILE: {0}}">
                    <i:Interaction.Triggers>
                        <i:DataTrigger Binding="{Binding Source={StaticResource BindingProxy}, Path=Data.EntryFile}" Value="{Binding}">
                            <i:ChangePropertyAction PropertyName="Foreground" Value="OrangeRed" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding Source={StaticResource BindingProxy}, Path=Data.EntryFile}"
                                       Comparison="NotEqual"
                                       Value="{Binding}">
                            <i:ChangePropertyAction PropertyName="Foreground" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=TreeViewItem}, Path=Foreground}" />
                        </i:DataTrigger>
                    </i:Interaction.Triggers>
                </TextBlock>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="10*" MinWidth="200" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Margin="0,8"
                           FontSize="20"
                           Text="BASE" />
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Border Width="60"
                            Height="60"
                            Margin="0,0,8,0"
                            Background="Transparent"
                            DockPanel.Dock="Left">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseEnter">
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="SelectIconButton"
                                                        Value="{x:Static Visibility.Visible}" />
                            </i:EventTrigger>
                            <i:EventTrigger EventName="MouseLeave">
                                <i:ChangePropertyAction PropertyName="Visibility"
                                                        TargetName="SelectIconButton"
                                                        Value="{x:Static Visibility.Hidden}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <Grid>
                            <Grid.Background>
                                <ImageBrush ImageSource="{Binding IconFile.FilePath}" />
                            </Grid.Background>
                            <Rectangle Stroke="#333333"
                                       StrokeDashArray="2 2"
                                       StrokeThickness="2" />
                            <Button x:Name="SelectIconButton"
                                    Width="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    av:Visibility="Visible"
                                    BorderThickness="0"
                                    Command="{Binding SetIconCmmand}"
                                    Content="+"
                                    FontSize="18"
                                    Visibility="Hidden" />
                        </Grid>
                    </Border>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0"
                                 Width="200"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Center"
                                 av:Text="PLUGIN NAME"
                                 Text="{Binding PluginManifest.PluginName, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Grid.Row="1"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBox Width="100"
                                     Margin="0,0,8,0"
                                     av:Text="AUTHOR"
                                     Text="{Binding PluginManifest.Author, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBox Width="80"
                                     av:Text="1.0.0"
                                     Text="{Binding PluginManifest.Version, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </DockPanel>
                <Grid Margin="0,8">
                    <TextBlock HorizontalAlignment="Left"
                               FontSize="20"
                               Text="PLUGIN FILES" />
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Margin="0,0,4,0"
                                Padding="16,4"
                                VerticalAlignment="Center"
                                Command="{Binding AddPluginFileCommand}"
                                CommandParameter="{Binding RootFolder}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16"
                                         Height="16"
                                         Margin="0,0,4,0">
                                    <Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                            Width="24"
                                            Height="24">
                                        <Path Data="M14 2H6C4.89 2 4 2.89 4 4V20C4 21.11 4.89 22 6 22H13.81C13.28 21.09 13 20.05 13 19C13 15.69 15.69 13 19 13C19.34 13 19.67 13.03 20 13.08V8L14 2M13 9V3.5L18.5 9H13M23 20H20V23H18V20H15V18H18V15H20V18H23V20Z" Fill="#000000" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock VerticalAlignment="Center" Text="FILE+" />
                            </StackPanel>
                        </Button>
                        <Button Padding="16,4"
                                VerticalAlignment="Center"
                                Command="{Binding AddPluginFolderCommand}"
                                CommandParameter="{Binding RootFolder}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16"
                                         Height="16"
                                         Margin="0,0,4,0">
                                    <Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                            Width="24"
                                            Height="24">
                                        <Path Data="M13 19C13 19.34 13.04 19.67 13.09 20H4C2.9 20 2 19.11 2 18V6C2 4.89 2.89 4 4 4H10L12 6H20C21.1 6 22 6.89 22 8V13.81C21.12 13.3 20.1 13 19 13C15.69 13 13 15.69 13 19M20 18V15H18V18H15V20H18V23H20V20H23V18H20Z" Fill="#000000" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock VerticalAlignment="Center" Text="FOLDER+" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

            </StackPanel>
            <TreeView Grid.Row="1"
                      Padding="0"
                      HorizontalContentAlignment="Stretch"
                      av:ItemsSource="{av:SampleData ItemCount=3}"
                      AllowDrop="True"
                      Background="Transparent"
                      BorderThickness="0"
                      Drop="PluginFilesTreeView_Drop"
                      FontSize="14"
                      ItemsSource="{Binding RootFolder.Children}">
                <i:Interaction.Behaviors>
                    <b:IgnoreMouseWheelBehavior />
                </i:Interaction.Behaviors>
                <TreeView.ItemTemplateSelector>
                    <selector:PluginItemDataTemplateSelector FileDataTemplate="{StaticResource PluginFileTemplate}" FolderDataTemplate="{StaticResource PluginFolderTemplate}" />
                </TreeView.ItemTemplateSelector>
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Padding" Value="4,2" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Foreground" Value="#EFEFEF" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Grid>
        <GridSplitter Grid.Column="1"
                      Width="3"
                      Margin="24,0"
                      Background="Gray"
                      ResizeBehavior="PreviousAndNext" />
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Margin="0,8"
                           FontSize="20"
                           Text="PROPERTIES" />
                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="PLUGIN ID" />
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Button Padding="16,4"
                            Command="{Binding GenPluginIdCommand}"
                            Content="GEN"
                            DockPanel.Dock="Right"
                            FontSize="14" />
                    <TextBox VerticalContentAlignment="Center"
                             av:Text="ID"
                             FontSize="14"
                             Text="{Binding PluginManifest.Id, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="OUTPUT FOLDER" />
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Button Padding="8,4"
                            Command="{Binding SetOutputFolderCommand}"
                            Content="SELECT FOLDER"
                            DockPanel.Dock="Right"
                            FontSize="14" />
                    <TextBox VerticalContentAlignment="Center"
                             FontSize="14"
                             IsReadOnly="True"
                             Text="{Binding OutputFolder}" />
                </DockPanel>
                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="DESCRIPTION" />
                <TextBox MinHeight="60"
                         Margin="0,0,0,8"
                         av:Text="DESCRIPTION"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontSize="14"
                         Text="{Binding PluginManifest.Description, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="MANIFEST" />
                <TextBox MinHeight="80"
                         Margin="0,0,0,8"
                         FontSize="14"
                         IsReadOnly="True"
                         Text="{Binding ManifestFileContent}" />
            </StackPanel>
            <Button Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="24,4"
                    HorizontalAlignment="Right"
                    Command="{Binding PackPluginCommand}"
                    Content="PACK"
                    FontSize="20" />
        </Grid>
    </Grid>
</UserControl>
