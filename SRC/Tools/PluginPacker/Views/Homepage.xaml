<UserControl x:Class="PluginPacker.Views.Homepage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:PluginPacker.Models"
             xmlns:powerlab="http://ui.powerlab.com/"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:system="clr-namespace:System;assembly=netstandard"
             xmlns:viewmodels="clr-namespace:PluginPacker.ViewModels"
             av:DataContext="{av:DesignInstance Type=viewmodels:HomepageViewModel}"
             av:DesignHeight="550"
             av:DesignWidth="895"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="#212121"
             Foreground="#EFEFEF"
             mc:Ignorable="av">
    <UserControl.Resources>
        <powerlab:BindingProxy x:Key="BindingProxy" Data="{Binding}" />
        <DataTemplate x:Key="PluginFileTemplate" DataType="{x:Type models:PluginFile}">
            <Border Background="#333333" CornerRadius="4">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.SetEntryFileCommand}"
                                  CommandParameter="{Binding}"
                                  Header="SET ENTRY" />
                        <MenuItem Command="{Binding Source={StaticResource BindingProxy}, Path=Data.RemovePluginFileCommand}"
                                  CommandParameter="{Binding}"
                                  Header="DELETE" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid Margin="8">
                    <TextBlock VerticalAlignment="Center"
                               av:Text="plugin_file.dll"
                               Text="{Binding FileName}" />
                    <Border Padding="8,4"
                            HorizontalAlignment="Right"
                            Background="#1E4694FB"
                            CornerRadius="4">
                        <i:Interaction.Triggers>
                            <i:DataTrigger Binding="{Binding IsEntryFile}" Value="True">
                                <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Visible}" />
                            </i:DataTrigger>
                            <i:DataTrigger Binding="{Binding IsEntryFile}" Value="False">
                                <i:ChangePropertyAction PropertyName="Visibility" Value="{x:Static Visibility.Hidden}" />
                            </i:DataTrigger>
                        </i:Interaction.Triggers>
                        <TextBlock Foreground="#FF3394FF" Text="EntryPoint" />
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*" MinWidth="300" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="10*" MinWidth="200" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Margin="0,8"
                       FontSize="20"
                       Text="BASE" />
            <DockPanel Margin="0,0,0,8" LastChildFill="True">
                <Border Width="60"
                        Height="60"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        DockPanel.Dock="Left">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseEnter">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="SelectIconButton"
                                                    Value="{x:Static Visibility.Visible}" />
                        </i:EventTrigger>
                        <i:EventTrigger EventName="MouseLeave">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    TargetName="SelectIconButton"
                                                    Value="{x:Static Visibility.Hidden}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <Grid>
                        <Grid.Background>
                            <ImageBrush ImageSource="{Binding IconFile.FilePath}"/>
                        </Grid.Background>
                        <Rectangle Stroke="#333333"
                                   StrokeDashArray="2 2"
                                   StrokeThickness="2" />
                        <Button x:Name="SelectIconButton"
                                Width="30"
                                Command="{Binding SetIconCmmand}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                BorderThickness="0"
                                Content="+"
                                Visibility="Hidden"
                                av:Visibility="Visible"
                                FontSize="18" />
                    </Grid>
                </Border>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0"
                             Width="200"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             av:Text="PLUGIN NAME"
                             Text="{Binding PluginManifest.PluginName, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBox Width="100"
                                 Margin="0,0,8,0"
                                 av:Text="AUTHOR"
                                 Text="{Binding PluginManifest.Author, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Width="80"
                                 av:Text="1.0.0"
                                 Text="{Binding PluginManifest.Version, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </DockPanel>
            <TextBlock Margin="0,8"
                       FontSize="20"
                       Text="PLUGIN FILES" />
            <Grid Height="150"
                  Margin="0,0,0,8"
                  Background="Transparent">
                <i:Interaction.Behaviors>
                    <powerlab:DropCommandBehavior Command="{Binding DropPluginFilesCommand}" />
                </i:Interaction.Behaviors>
                <Rectangle RadiusX="4"
                           RadiusY="4"
                           Stroke="#333333"
                           StrokeDashArray="2, 2"
                           StrokeThickness="2" />
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,0,8" Text="将文件从文件管理器或桌面拖放到此处即可添加文件" />
                    <Button Padding="16,4"
                            HorizontalAlignment="Center"
                            Command="{Binding OpenFileCommand}"
                            Content="浏览并添加文件" />
                </StackPanel>
            </Grid>
            <ItemsControl av:ItemsSource="{av:SampleData ItemCount=3}"
                          FontSize="14"
                          ItemTemplate="{StaticResource PluginFileTemplate}"
                          ItemsSource="{Binding PluginFiles}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="{x:Type ContentPresenter}">
                        <Setter Property="Margin" Value="0,0,0,4" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </StackPanel>
        <GridSplitter Grid.Column="1"
                      Width="3"
                      Margin="24,0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Gray" />
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <TextBlock Margin="0,8"
                           FontSize="20"
                           Text="PROPERTIES" />
                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="PLUGIN ID" />
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Button Padding="16,4"
                            Command="{Binding GenPluginIdCommand}"
                            Content="GEN"
                            DockPanel.Dock="Right"
                            FontSize="14" />
                    <TextBox VerticalContentAlignment="Center"
                             av:Text="ID"
                             FontSize="14"
                             Text="{Binding PluginManifest.Id, UpdateSourceTrigger=PropertyChanged}" />
                </DockPanel>

                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="OUTPUT FOLDER" />
                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                    <Button Padding="8,4"
                            Command="{Binding SetOutputFolderCommand}"
                            Content="SELECT FOLDER"
                            DockPanel.Dock="Right"
                            FontSize="14" />
                    <TextBox VerticalContentAlignment="Center"
                             FontSize="14"
                             IsReadOnly="True"
                             Text="{Binding OutputFolder}" />
                </DockPanel>
                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="DESCRIPTION" />
                <TextBox MinHeight="60"
                         Margin="0,0,0,8"
                         av:Text="DESCRIPTION"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontSize="14"
                         Text="{Binding PluginManifest.Description, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,0,0,4"
                           FontSize="16"
                           Text="MANIFEST" />
                <TextBox MinHeight="80"
                         Margin="0,0,0,8"
                         FontSize="14"
                         IsReadOnly="True"
                         Text="{Binding ManifestFileContent}" />
            </StackPanel>
            <Button Grid.Row="1"
                    Margin="0,12,0,0"
                    Padding="24,4"
                    HorizontalAlignment="Right"
                    Command="{Binding PackPluginCommand}"
                    Content="PACK"
                    FontSize="20" />
        </Grid>
    </Grid>
</UserControl>
