                        xmlns:local="clr-namespace:PluginPacker"
                        xmlns:powerlab="http://ui.powerlab.com/"
                        xmlns:prism="http://prismlibrary.com/">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <x:Static Member="powerlab:DarkTheme.Instance" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</prism:PrismApplication>
